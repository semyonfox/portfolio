---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const games = (await getCollection('games')).sort(
  (a, b) => a.data.order - b.data.order,
);

const gamePreviewClass: Record<string, string> = {
  'space-invaders': 'game-thumb--space-invaders',
  'maze-chase': 'game-thumb--maze-chase',
  'game-of-life': 'game-thumb--game-of-life',
  artificial: 'game-thumb--artificial',
  'cellular-caves': 'game-thumb--cellular-caves',
  'gacha-bot': 'game-thumb--gacha-bot',
  'clicker-game': 'game-thumb--clicker-game',
};
---

<Layout
  title="Games | Semyon Fox"
  description="Games and apps I've built that you can actually play."
>
  <section class="pt-20 pb-16 md:pt-28">
    <h1 class="type-page-title mb-3">Games & Apps</h1>
    <p class="type-body mb-12">games and other interactive things i've built</p>

    <!-- catalog grid -->
    <div
      id="game-catalog"
      class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4"
    >
      {
        games.map((game) => (
          <button
            class="game-card bg-surface border border-heading/[0.06] rounded-bento overflow-hidden hover:border-heading/10 transition-colors text-left group"
            data-game-id={game.id}
            data-game-title={game.data.title}
            data-game-tech={game.data.tech}
            data-game-github={game.data.github || ''}
            data-game-private={game.data.private ? 'true' : 'false'}
            data-game-embed={game.data.embed || ''}
            data-game-noembed={game.data.noEmbed || ''}
            data-game-display-width={game.data.displayWidth || ''}
            data-game-display-height={game.data.displayHeight || ''}
          >
            {game.data.thumbnail ? (
              <img
                src={game.data.thumbnail}
                alt=""
                width="960"
                height="540"
                class="w-full h-36 md:h-44 object-cover border-b border-border"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div
                class:list={[
                  'game-thumb',
                  gamePreviewClass[game.id] || 'game-thumb--default',
                ]}
                aria-hidden="true"
              >
                <span class="game-thumb-screen" />
              </div>
            )}
            <div class="p-4">
              <h3 class="type-small-title group-hover:text-fox/90 transition-colors">
                {game.data.title}
              </h3>
              <p class="text-muted text-sm mt-1.5 line-clamp-2 leading-relaxed">
                {game.data.description}
              </p>
              <p class="text-dim text-xs mt-2">{game.data.tech}</p>
            </div>
          </button>
        ))
      }
    </div>

    <!-- game player (hidden by default) -->
    <div id="game-player" class="hidden">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 id="player-title" class="type-section-title"></h2>
          <p id="player-tech" class="text-dim text-xs mt-1"></p>
        </div>
        <div class="flex gap-2">
          <a
            id="player-github"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="hidden border border-border text-muted text-xs px-3 py-1.5 rounded-lg hover:text-heading hover:border-muted transition-colors"
          >
            github
          </a>
          <span
            id="player-private"
            class="hidden border border-border text-muted text-xs px-3 py-1.5 rounded-lg"
          >
            private repo
          </span>
          <button
            id="player-fullscreen"
            class="border border-border text-muted text-xs px-3 py-1.5 rounded-lg hover:text-heading hover:border-muted transition-colors"
          >
            fullscreen
          </button>
          <button
            id="player-back"
            class="border border-border text-muted text-xs px-3 py-1.5 rounded-lg hover:text-heading hover:border-muted transition-colors"
          >
            back
          </button>
        </div>
      </div>
      <div class="bg-black rounded-bento overflow-hidden border border-border">
        <iframe
          id="player-frame"
          class="w-full aspect-video"
          allow="fullscreen"
          tabindex="0"
          title="Game player"></iframe>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .game-thumb {
    position: relative;
    height: 9rem;
    overflow: hidden;
    border-bottom: 1px solid #252525;
    background: #1f1f1f;
    isolation: isolate;
  }

  @media (min-width: 48rem) {
    .game-thumb {
      height: 11rem;
    }
  }

  .game-thumb::before,
  .game-thumb::after,
  .game-thumb-screen {
    content: '';
    position: absolute;
    display: block;
  }

  .game-thumb-screen {
    inset: 0;
    z-index: 3;
    background:
      linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px) 0 0 /
        100% 10px,
      radial-gradient(
        circle at 30% 20%,
        rgba(255, 255, 255, 0.08),
        transparent 18%
      ),
      linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.22));
    opacity: 0.7;
    pointer-events: none;
  }

  .game-thumb--space-invaders {
    background:
      radial-gradient(circle at 18% 24%, #f0f0f0 0 1px, transparent 1.5px),
      radial-gradient(circle at 64% 18%, #f0f0f0 0 1px, transparent 1.5px),
      radial-gradient(circle at 78% 56%, #f0f0f0 0 1px, transparent 1.5px),
      linear-gradient(180deg, #111827, #151515);
  }

  .game-thumb--space-invaders::before {
    width: 12px;
    height: 12px;
    left: 50%;
    top: 35%;
    translate: -50% -50%;
    background: #8fe6ff;
    box-shadow:
      -44px 0 0 #8fe6ff,
      44px 0 0 #8fe6ff,
      -22px 24px 0 #e8702a,
      22px 24px 0 #e8702a;
  }

  .game-thumb--space-invaders::after {
    width: 58px;
    height: 10px;
    left: 50%;
    bottom: 28px;
    translate: -50% 0;
    background: #e8702a;
    clip-path: polygon(50% 0, 100% 100%, 0 100%);
  }

  .game-thumb--maze-chase {
    background:
      linear-gradient(90deg, transparent 47%, #2f5cff 48% 52%, transparent 53%),
      linear-gradient(transparent 30%, #2f5cff 31% 35%, transparent 36%),
      linear-gradient(
        90deg,
        #2f5cff 8%,
        transparent 8% 28%,
        #2f5cff 28% 32%,
        transparent 32% 70%,
        #2f5cff 70% 74%,
        transparent 74%
      ),
      #111421;
  }

  .game-thumb--maze-chase::before {
    width: 18px;
    height: 18px;
    left: 28%;
    top: 56%;
    border-radius: 999px;
    background: #e8702a;
    box-shadow: 84px -42px 0 #8fe6ff;
  }

  .game-thumb--maze-chase::after {
    width: 42px;
    height: 4px;
    left: 48%;
    top: 50%;
    background: #f0f0f0;
    opacity: 0.5;
  }

  .game-thumb--game-of-life {
    background:
      linear-gradient(#242424 1px, transparent 1px) 0 0 / 18px 18px,
      linear-gradient(90deg, #242424 1px, transparent 1px) 0 0 / 18px 18px,
      #111;
  }

  .game-thumb--game-of-life::before {
    width: 12px;
    height: 12px;
    left: 36%;
    top: 36%;
    background: #8fe6ff;
    box-shadow:
      18px 0 0 #8fe6ff,
      36px 0 0 #e8702a,
      18px 18px 0 #8fe6ff,
      36px 18px 0 #8fe6ff,
      54px 36px 0 #e8702a,
      18px 54px 0 #8fe6ff;
  }

  .game-thumb--artificial {
    background:
      linear-gradient(90deg, rgba(232, 112, 42, 0.18), transparent),
      linear-gradient(180deg, #1a1411, #151515);
  }

  .game-thumb--artificial::before {
    width: 72%;
    height: 2px;
    left: 14%;
    top: 52%;
    background: #e8702a;
    box-shadow:
      0 -30px 0 rgba(232, 112, 42, 0.28),
      0 30px 0 rgba(232, 112, 42, 0.18);
  }

  .game-thumb--artificial::after {
    width: 14px;
    height: 14px;
    left: 22%;
    top: 47%;
    border-radius: 999px;
    background: #f0f0f0;
    box-shadow:
      64px 0 0 #e8702a,
      128px 0 0 #8fe6ff,
      192px 0 0 #e8702a;
  }

  .game-thumb--cellular-caves {
    background:
      radial-gradient(
        circle at 22% 50%,
        transparent 0 24px,
        #193f35 25px 48px,
        transparent 49px
      ),
      radial-gradient(
        circle at 63% 34%,
        transparent 0 34px,
        #193f35 35px 62px,
        transparent 63px
      ),
      radial-gradient(
        circle at 74% 72%,
        transparent 0 30px,
        #193f35 31px 58px,
        transparent 59px
      ),
      #0f1614;
  }

  .game-thumb--cellular-caves::before {
    inset: 18px;
    border: 1px solid rgba(143, 230, 255, 0.18);
  }

  .game-thumb--cellular-caves::after {
    width: 36px;
    height: 6px;
    right: 28px;
    bottom: 30px;
    background: #8fe6ff;
    opacity: 0.8;
  }

  .game-thumb--gacha-bot {
    background: linear-gradient(180deg, #101010, #171717);
  }

  .game-thumb--gacha-bot::before {
    width: 70%;
    height: 8px;
    left: 16%;
    top: 30%;
    background: #6a6a6a;
    box-shadow:
      0 20px 0 #e8702a,
      0 40px 0 #6a6a6a,
      0 60px 0 #949494;
  }

  .game-thumb--gacha-bot::after {
    content: '> run pull --rare';
    left: 16%;
    bottom: 24px;
    color: #e8702a;
    font-size: 12px;
    font-weight: 700;
  }

  .game-thumb--clicker-game {
    background: linear-gradient(180deg, #17120f, #151515);
  }

  .game-thumb--clicker-game::before {
    width: 56px;
    height: 56px;
    left: 50%;
    top: 46%;
    translate: -50% -50%;
    border-radius: 8px;
    border: 2px solid #e8702a;
    background: rgba(232, 112, 42, 0.12);
  }

  .game-thumb--clicker-game::after {
    width: 34px;
    height: 5px;
    left: 50%;
    bottom: 28px;
    translate: -50% 0;
    background: #949494;
    box-shadow:
      -42px 0 0 #6a6a6a,
      42px 0 0 #6a6a6a;
  }

  .game-thumb--default {
    background:
      linear-gradient(135deg, rgba(232, 112, 42, 0.2), transparent), #151515;
  }
</style>

<script>
  const catalog = document.getElementById('game-catalog');
  const player = document.getElementById('game-player');
  const frame = document.getElementById('player-frame') as HTMLIFrameElement;
  const title = document.getElementById('player-title');
  const tech = document.getElementById('player-tech');
  const githubLink = document.getElementById(
    'player-github',
  ) as HTMLAnchorElement;
  const privateRepo = document.getElementById('player-private');
  const backBtn = document.getElementById('player-back');
  const fullscreenBtn = document.getElementById('player-fullscreen');

  document.querySelectorAll('.game-card').forEach((card) => {
    card.addEventListener('click', () => {
      const el = card as HTMLElement;
      const embedUrl = el.dataset.gameEmbed;

      if (title) title.textContent = el.dataset.gameTitle || '';
      if (tech) tech.textContent = el.dataset.gameTech || '';

      if (el.dataset.gamePrivate === 'true') {
        githubLink?.classList.add('hidden');
        privateRepo?.classList.remove('hidden');
      } else if (el.dataset.gameGithub && githubLink) {
        githubLink.href = el.dataset.gameGithub;
        githubLink.classList.remove('hidden');
        privateRepo?.classList.add('hidden');
      } else if (githubLink) {
        githubLink.classList.add('hidden');
        privateRepo?.classList.add('hidden');
      }

      if (embedUrl && frame) {
        frame.src = embedUrl;
        window.setTimeout(() => frame.focus(), 0);
        const displayWidth = Number(el.dataset.gameDisplayWidth);
        const displayHeight = Number(el.dataset.gameDisplayHeight);
        if (displayWidth > 0 && displayHeight > 0) {
          frame.style.aspectRatio = `${displayWidth} / ${displayHeight}`;
        } else {
          frame.style.aspectRatio = '';
        }
      } else if (frame) {
        const msg = el.dataset.gameNoembed || 'Game embed coming soon';
        frame.style.aspectRatio = '';
        frame.srcdoc = `<div style="display:flex;align-items:center;justify-content:center;height:100%;background:#0a0a0a;color:#666;font-family:system-ui;font-size:14px;"><p>${msg}</p></div>`;
      }

      catalog?.classList.add('hidden');
      player?.classList.remove('hidden');
    });
  });

  backBtn?.addEventListener('click', () => {
    player?.classList.add('hidden');
    catalog?.classList.remove('hidden');
    if (frame) frame.src = '';
  });

  fullscreenBtn?.addEventListener('click', () => {
    frame?.requestFullscreen?.();
  });
</script>
