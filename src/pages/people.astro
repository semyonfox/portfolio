---
import Layout from '../layouts/Layout.astro';
import { categoryOrder, people, type PersonCategory } from '../data/people';
import semanticGraph from '../data/people-graph.json';

const categoryMeta: Record<
  PersonCategory,
  {
    label: string;
    blurb: string;
    cardClass: string;
    chipClass: string;
  }
> = {
  dev: {
    label: 'Dev / Software',
    blurb: 'tooling, programming taste, systems, and internet dev culture',
    cardClass: 'border-fox/20 bg-fox/[0.03]',
    chipClass: 'border-fox/25 bg-fox/[0.08] text-heading hover:bg-fox/[0.14]',
  },
  science: {
    label: 'Math / Science / Engineering',
    blurb: 'channels that make hard things feel intuitive instead of distant',
    cardClass: 'border-sky-500/20 bg-sky-500/[0.03]',
    chipClass:
      'border-sky-500/25 bg-sky-500/[0.08] text-heading hover:bg-sky-500/[0.14]',
  },
  hardware: {
    label: 'Hardware / Maker / Tech',
    blurb: 'pcs, hardware reviews, clean builds, and hands-on making',
    cardClass: 'border-emerald-500/20 bg-emerald-500/[0.03]',
    chipClass:
      'border-emerald-500/25 bg-emerald-500/[0.08] text-heading hover:bg-emerald-500/[0.14]',
  },
  swimming: {
    label: 'Swimming / Sport',
    blurb: 'people i watch for race craft, speed, consistency, and standards',
    cardClass: 'border-cyan-500/20 bg-cyan-500/[0.03]',
    chipClass:
      'border-cyan-500/25 bg-cyan-500/[0.08] text-heading hover:bg-cyan-500/[0.14]',
  },
  games: {
    label: 'Games / Internet',
    blurb: 'game design, minecraft orbit, and internet chaos',
    cardClass: 'border-violet-500/20 bg-violet-500/[0.03]',
    chipClass:
      'border-violet-500/25 bg-violet-500/[0.08] text-heading hover:bg-violet-500/[0.14]',
  },
  creative: {
    label: 'Film / Creative',
    blurb: 'editing, production, storytelling, and polished creator craft',
    cardClass: 'border-amber-500/20 bg-amber-500/[0.03]',
    chipClass:
      'border-amber-500/25 bg-amber-500/[0.08] text-heading hover:bg-amber-500/[0.14]',
  },
  chess: {
    label: 'Chess',
    blurb: 'competitive thinking, explanation, and pattern recognition',
    cardClass: 'border-red-500/20 bg-red-500/[0.03]',
    chipClass:
      'border-red-500/25 bg-red-500/[0.08] text-heading hover:bg-red-500/[0.14]',
  },
  comedy: {
    label: 'Comedy / Entertainment',
    blurb: 'stuff that is just fun, sharp, or entertainingly unhinged',
    cardClass: 'border-zinc-500/20 bg-zinc-500/[0.03]',
    chipClass:
      'border-zinc-500/25 bg-zinc-500/[0.08] text-heading hover:bg-zinc-500/[0.14]',
  },
};

const grouped = Object.fromEntries(
  categoryOrder.map((category) => [
    category,
    people
      .filter((person) => person.category === category)
      .sort((a, b) => b.weight - a.weight || a.name.localeCompare(b.name)),
  ]),
) as Record<PersonCategory, typeof people>;

const graphColors: Record<PersonCategory, string> = {
  dev: '#e8702a',
  science: '#40b8ff',
  hardware: '#119b74',
  swimming: '#16b8d8',
  games: '#6f4bd6',
  creative: '#c88a13',
  chess: '#d84848',
  comedy: '#686874',
};

const categoryCenters: Record<PersonCategory, { x: number; y: number }> = {
  dev: { x: 210, y: 160 },
  science: { x: 500, y: 120 },
  hardware: { x: 790, y: 170 },
  swimming: { x: 160, y: 450 },
  games: { x: 425, y: 500 },
  creative: { x: 680, y: 450 },
  chess: { x: 905, y: 420 },
  comedy: { x: 560, y: 315 },
};

const graphNodes = categoryOrder.flatMap((category) => {
  const members = grouped[category];
  const center = categoryCenters[category];

  return members.map((person, index) => {
    const angle = (Math.PI * 2 * index) / Math.max(members.length, 1);
    const ring = 36 + Math.floor(index / 5) * 34 + (5 - person.weight) * 5;
    const driftX = Math.sin(index * 1.7) * 10;
    const driftY = Math.cos(index * 1.3) * 8;
    const x = center.x + Math.cos(angle) * ring + driftX;
    const y = center.y + Math.sin(angle) * ring + driftY;

    return {
      ...person,
      semantic: semanticGraph.nodes[person.slug],
      x,
      y,
      visualWeight: Math.max(
        person.weight,
        Math.round(
          (person.weight +
            (semanticGraph.nodes[person.slug]?.graphWeight || person.weight)) /
            2,
        ),
      ),
      color: graphColors[category],
    };
  });
});

const slugSet = new Set(graphNodes.map((node) => node.slug));

const explicitEdges = new Set<string>();
const graphEdges: Array<{
  source: string;
  target: string;
  inferred: boolean;
  score?: number;
}> = [];

for (const person of graphNodes) {
  for (const target of person.connections || []) {
    if (!slugSet.has(target)) continue;
    const [a, b] = [person.slug, target].sort();
    const key = `${a}:${b}`;
    if (explicitEdges.has(key)) continue;
    explicitEdges.add(key);
    graphEdges.push({ source: a, target: b, inferred: false });
  }
}

for (const edge of semanticGraph.semanticEdges) {
  const key = [edge.source, edge.target].sort().join(':');
  if (explicitEdges.has(key)) continue;
  if (!slugSet.has(edge.source) || !slugSet.has(edge.target)) continue;
  graphEdges.push({
    source: edge.source,
    target: edge.target,
    inferred: true,
    score: edge.score,
  });
}

const defaultPerson = graphNodes[0];
---

<Layout
  title="People | Semyon Fox"
  description="Interesting people, channels, and internet rabbit holes I keep coming back to."
>
  <section class="pt-20 pb-16 md:pt-28">
    <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-2">
      Interesting People/Videos
    </h1>
    <p class="text-muted text-sm mb-4">
      some of my favorite content creators and internet people
    </p>
    <p class="text-dim text-xs max-w-2xl leading-relaxed">
      weight roughly means how central they are to my feed, interests, or
      thinking. solid links are direct connections i care about; faint links are
      inferred from semantic similarity using embedded wiki or fallback profile
      text. this should feel more like a colored obsidian graph than a rigid
      category diagram.
    </p>
  </section>

  <section class="pb-16">
    <div class="flex items-center gap-3 mb-6">
      <span class="text-dim text-xs uppercase tracking-[3px]">signal map</span>
      <span class="text-dim text-xs">weighted nodes, clustered by interest</span
      >
    </div>

    <div class="grid xl:grid-cols-[1.9fr_1fr] gap-4">
      <div
        class="bg-surface border border-heading/[0.06] rounded-bento p-3 md:p-5 overflow-hidden"
      >
        <svg
          id="people-graph"
          viewBox="0 0 1000 620"
          class="w-full h-auto"
          aria-label="Graph of interesting people and creators"
        >
          <rect x="0" y="0" width="1000" height="620" fill="#171726"></rect>

          {
            graphEdges.map((edge, index) => {
              const source = graphNodes.find(
                (node) => node.slug === edge.source,
              )!;
              const target = graphNodes.find(
                (node) => node.slug === edge.target,
              )!;
              return (
                <line
                  x1={source.x}
                  y1={source.y}
                  x2={target.x}
                  y2={target.y}
                  stroke={edge.inferred ? '#666b8f' : '#8d93b8'}
                  stroke-opacity={edge.inferred ? '0.18' : '0.34'}
                  stroke-width={edge.inferred ? '0.7' : '1'}
                  data-edge-index={index}
                  data-edge-source={edge.source}
                  data-edge-target={edge.target}
                />
              );
            })
          }

          {
            graphNodes.map((person) => (
              <g
                data-node={person.slug}
                class="cursor-pointer transition-opacity"
                tabindex="0"
                role="button"
                aria-label={`Select ${person.name}`}
              >
                <circle
                  data-node-glow={person.slug}
                  cx={person.x}
                  cy={person.y}
                  r={8 + person.visualWeight * 2.6}
                  fill={person.color}
                  fill-opacity="0.03"
                />
                <circle
                  data-node-ring={person.slug}
                  cx={person.x}
                  cy={person.y}
                  r={2 + person.visualWeight * 1.8}
                  fill={person.color}
                  fill-opacity="0.04"
                  stroke={person.color}
                  stroke-width="1.1"
                />
                <circle
                  data-node-core={person.slug}
                  cx={person.x}
                  cy={person.y}
                  r={1.3 + person.visualWeight * 0.9}
                  fill={person.color}
                />
                <text
                  data-label={person.slug}
                  x={person.x}
                  y={person.y + 16}
                  text-anchor="middle"
                  fill="#d8dbef"
                  font-size={person.weight >= 4 ? '11' : '10'}
                  opacity={person.weight >= 5 ? '0.14' : '0.04'}
                >
                  {person.name}
                </text>
              </g>
            ))
          }
        </svg>
      </div>

      <aside
        id="people-detail"
        class="bg-surface border border-heading/[0.06] rounded-bento p-5"
      >
        <p class="text-dim text-[11px] uppercase tracking-[3px] mb-3">
          selected node
        </p>
        <button
          id="graph-reset"
          type="button"
          class="mb-4 border border-border text-muted text-[11px] px-2.5 py-1 rounded hover:text-heading hover:border-muted transition-colors"
        >
          reset view
        </button>
        <div class="flex items-start justify-between gap-4 mb-3">
          <div>
            <h2 id="detail-name" class="text-heading text-xl font-bold">
              {defaultPerson.name}
            </h2>
            <p id="detail-category" class="text-dim text-xs mt-1">
              {categoryMeta[defaultPerson.category].label} · signal {
                defaultPerson.weight
              }/5 · graph {
                defaultPerson.semantic?.graphWeight || defaultPerson.weight
              }/5
            </p>
          </div>
          <a
            id="detail-primary"
            href={defaultPerson.links.primary}
            target="_blank"
            rel="noopener noreferrer"
            class="shrink-0 border border-border text-muted text-xs px-3 py-1.5 rounded-lg hover:text-heading hover:border-muted transition-colors"
          >
            open
          </a>
        </div>

        <p id="detail-summary" class="text-muted text-sm leading-relaxed mb-4">
          {defaultPerson.semantic?.summary || defaultPerson.summary}
        </p>

        <div id="detail-tags" class="flex flex-wrap gap-1.5 mb-4">
          {
            defaultPerson.tags.map((tag) => (
              <span class="bg-border px-2 py-0.5 rounded text-[11px] text-muted">
                {tag}
              </span>
            ))
          }
        </div>

        <div class="space-y-3">
          <div>
            <p class="text-dim text-[11px] uppercase tracking-[3px] mb-2">
              links
            </p>
            <div id="detail-links" class="flex flex-wrap gap-2"></div>
          </div>

          <div>
            <p class="text-dim text-[11px] uppercase tracking-[3px] mb-2">
              nearby nodes
            </p>
            <div id="detail-connections" class="flex flex-wrap gap-2"></div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="pb-16">
    <div class="flex items-center gap-3 mb-6">
      <span class="text-dim text-xs uppercase tracking-[3px]">directory</span>
      <span class="text-dim text-xs">
        grouped entries with quick links out to content
      </span>
    </div>

    <div class="space-y-8">
      {
        categoryOrder.map((category) => (
          <section>
            <div class="mb-4">
              <h2 class="text-heading text-xl font-bold tracking-tight">
                {categoryMeta[category].label}
              </h2>
              <p class="text-muted text-sm mt-1">
                {categoryMeta[category].blurb}
              </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-3">
              {grouped[category].map((person) => (
                <article class="bg-surface border border-heading/[0.06] rounded-bento p-5 hover:border-heading/10 transition-colors">
                  <div class="flex items-start justify-between gap-4 mb-3">
                    <div>
                      <h3 class="text-heading text-sm font-semibold">
                        {person.name}
                      </h3>
                      <p class="text-dim text-[11px] mt-1">
                        signal {person.weight}/5
                      </p>
                    </div>
                    <a
                      href={person.links.primary}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="shrink-0 border border-border text-muted text-[11px] px-2.5 py-1 rounded hover:text-heading hover:border-muted transition-colors"
                    >
                      open
                    </a>
                  </div>

                  <p class="text-muted text-xs leading-relaxed mb-3">
                    {semanticGraph.nodes[person.slug]?.summary ||
                      person.summary}
                  </p>

                  <div class="flex flex-wrap gap-1.5 mb-3">
                    {person.tags.map((tag) => (
                      <span class="bg-border px-2 py-0.5 rounded text-[11px] text-muted">
                        {tag}
                      </span>
                    ))}
                  </div>

                  {person.connections && person.connections.length > 0 && (
                    <p class="text-dim text-[11px] leading-relaxed">
                      explicit links: {person.connections.length}
                    </p>
                  )}
                </article>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </section>
</Layout>

<script
  define:vars={{
    people: graphNodes,
    edges: graphEdges,
    categoryMeta,
    categoryCenters,
  }}
>
  const nodes = people;
  const edgeList = edges;
  const nodeEls = Array.from(document.querySelectorAll('[data-node]'));
  const labelEls = Array.from(document.querySelectorAll('[data-label]'));
  const edgeEls = Array.from(
    document.querySelectorAll('[data-edge-source][data-edge-target]'),
  );
  const graphSvg = document.getElementById('people-graph');
  const nodeGlows = new Map(
    nodes.map((node) => [
      node.slug,
      document.querySelector(`[data-node-glow="${node.slug}"]`),
    ]),
  );
  const nodeRings = new Map(
    nodes.map((node) => [
      node.slug,
      document.querySelector(`[data-node-ring="${node.slug}"]`),
    ]),
  );
  const nodeCores = new Map(
    nodes.map((node) => [
      node.slug,
      document.querySelector(`[data-node-core="${node.slug}"]`),
    ]),
  );

  const detailName = document.getElementById('detail-name');
  const detailCategory = document.getElementById('detail-category');
  const detailSummary = document.getElementById('detail-summary');
  const detailPrimary = document.getElementById('detail-primary');
  const detailTags = document.getElementById('detail-tags');
  const detailLinks = document.getElementById('detail-links');
  const detailConnections = document.getElementById('detail-connections');
  const resetBtn = document.getElementById('graph-reset');

  const nodeMap = new Map(nodes.map((node) => [node.slug, node]));
  const positionMap = new Map(
    nodes.map((node) => [
      node.slug,
      {
        x: node.x,
        y: node.y,
        vx: 0,
        vy: 0,
      },
    ]),
  );
  const width = 1000;
  const height = 620;
  const padding = 24;

  const linkOrder = [
    'youtube',
    'x',
    'github',
    'linkedin',
    'website',
    'primary',
  ];
  const linkLabels = {
    youtube: 'youtube',
    x: 'x',
    github: 'github',
    linkedin: 'linkedin',
    website: 'site',
    primary: 'open',
  };

  function renderLinks(person) {
    if (!detailLinks) return;
    detailLinks.innerHTML = '';

    const seen = new Set();

    for (const key of linkOrder) {
      const href = person.links?.[key];
      if (!href || seen.has(href)) continue;
      seen.add(href);

      const a = document.createElement('a');
      a.href = href;
      a.target = '_blank';
      a.rel = 'noopener noreferrer';
      a.className =
        'border border-border text-muted text-[11px] px-2.5 py-1 rounded hover:text-heading hover:border-muted transition-colors';
      a.textContent = linkLabels[key];
      detailLinks.appendChild(a);
    }
  }

  function renderConnections(person) {
    if (!detailConnections) return;
    detailConnections.innerHTML = '';

    const nearby = new Set(person.connections || []);
    for (const edge of edgeList) {
      if (edge.source === person.slug) nearby.add(edge.target);
      if (edge.target === person.slug) nearby.add(edge.source);
    }

    for (const slug of nearby) {
      const target = nodeMap.get(slug);
      if (!target) continue;

      const button = document.createElement('button');
      button.type = 'button';
      button.className =
        'bg-border px-2 py-0.5 rounded text-[11px] text-muted hover:text-heading transition-colors';
      button.textContent = target.name;
      button.addEventListener('click', () => selectNode(slug));
      detailConnections.appendChild(button);
    }
  }

  function renderTags(person) {
    if (!detailTags) return;
    detailTags.innerHTML = '';

    for (const tag of person.tags || []) {
      const span = document.createElement('span');
      span.className = 'bg-border px-2 py-0.5 rounded text-[11px] text-muted';
      span.textContent = tag;
      detailTags.appendChild(span);
    }
  }

  function resetGraph() {
    nodeEls.forEach((el) => {
      el.style.opacity = '1';
    });

    edgeEls.forEach((el) => {
      const inferred = el.getAttribute('stroke-width') === '0.7';
      el.style.opacity = inferred ? '0.18' : '0.34';
    });

    labelEls.forEach((el) => {
      const slug = el.getAttribute('data-label');
      const person = slug ? nodeMap.get(slug) : null;
      if (!person) return;
      el.style.opacity = person.weight >= 5 ? '0.14' : '0.04';
    });
  }

  function tickLayout() {
    const entries = nodes.map((node) => ({
      node,
      pos: positionMap.get(node.slug),
    }));

    for (let i = 0; i < entries.length; i++) {
      for (let j = i + 1; j < entries.length; j++) {
        const a = entries[i];
        const b = entries[j];
        const dx = a.pos.x - b.pos.x;
        const dy = a.pos.y - b.pos.y;
        const distSq = dx * dx + dy * dy + 0.01;
        const dist = Math.sqrt(distSq);
        const force = 190 / distSq;
        const fx = (dx / dist) * force;
        const fy = (dy / dist) * force;
        a.pos.vx += fx;
        a.pos.vy += fy;
        b.pos.vx -= fx;
        b.pos.vy -= fy;
      }
    }

    for (const edge of edgeList) {
      const source = positionMap.get(edge.source);
      const target = positionMap.get(edge.target);
      if (!source || !target) continue;
      const dx = target.x - source.x;
      const dy = target.y - source.y;
      const dist = Math.sqrt(dx * dx + dy * dy) || 1;
      const desired = edge.inferred ? 78 : 54;
      const strength = edge.inferred ? 0.0025 : 0.006;
      const force = (dist - desired) * strength;
      const fx = (dx / dist) * force;
      const fy = (dy / dist) * force;
      source.vx += fx;
      source.vy += fy;
      target.vx -= fx;
      target.vy -= fy;
    }

    for (const { node, pos } of entries) {
      const anchor = categoryCenters[node.category];
      pos.vx += (anchor.x - pos.x) * 0.0005;
      pos.vy += (anchor.y - pos.y) * 0.0005;
      pos.vx += (width / 2 - pos.x) * 0.00005;
      pos.vy += (height / 2 - pos.y) * 0.00005;
      pos.vx *= 0.88;
      pos.vy *= 0.88;
      pos.x = Math.max(padding, Math.min(width - padding, pos.x + pos.vx));
      pos.y = Math.max(padding, Math.min(height - padding, pos.y + pos.vy));
    }
  }

  function renderLayout() {
    for (const node of nodes) {
      const pos = positionMap.get(node.slug);
      const group = document.querySelector(`[data-node="${node.slug}"]`);
      const glow = nodeGlows.get(node.slug);
      const ring = nodeRings.get(node.slug);
      const core = nodeCores.get(node.slug);
      const label = document.querySelector(`[data-label="${node.slug}"]`);
      if (!pos || !group || !glow || !ring || !core || !label) continue;

      glow.setAttribute('cx', pos.x);
      glow.setAttribute('cy', pos.y);
      ring.setAttribute('cx', pos.x);
      ring.setAttribute('cy', pos.y);
      core.setAttribute('cx', pos.x);
      core.setAttribute('cy', pos.y);
      label.setAttribute('x', pos.x);
      label.setAttribute('y', pos.y + 16);
    }

    edgeEls.forEach((el) => {
      const source = positionMap.get(el.getAttribute('data-edge-source'));
      const target = positionMap.get(el.getAttribute('data-edge-target'));
      if (!source || !target) return;
      el.setAttribute('x1', source.x);
      el.setAttribute('y1', source.y);
      el.setAttribute('x2', target.x);
      el.setAttribute('y2', target.y);
    });
  }

  function settleLayout(iterations = 180) {
    for (let i = 0; i < iterations; i++) {
      tickLayout();
    }
    renderLayout();
  }

  function selectNode(slug) {
    const person = nodeMap.get(slug);
    if (!person) return;

    const connected = new Set([slug]);
    for (const edge of edgeList) {
      if (edge.source === slug) connected.add(edge.target);
      if (edge.target === slug) connected.add(edge.source);
    }

    nodeEls.forEach((el) => {
      const active = connected.has(el.getAttribute('data-node') || '');
      el.style.opacity = active ? '1' : '0.24';
    });

    edgeEls.forEach((el) => {
      const source = el.getAttribute('data-edge-source');
      const target = el.getAttribute('data-edge-target');
      const active = source === slug || target === slug;
      el.style.opacity = active ? '0.95' : '0.08';
    });

    labelEls.forEach((el) => {
      const labelSlug = el.getAttribute('data-label') || '';
      const active = connected.has(labelSlug);
      el.style.opacity = active ? '0.95' : '0.02';
    });

    if (detailName) detailName.textContent = person.name;
    if (detailCategory) {
      detailCategory.textContent = `${categoryMeta[person.category].label} · signal ${person.weight}/5 · graph ${person.semantic?.graphWeight || person.weight}/5`;
    }
    if (detailSummary) {
      detailSummary.textContent = person.semantic?.summary || person.summary;
    }
    if (detailPrimary) detailPrimary.href = person.links.primary;

    renderTags(person);
    renderLinks(person);
    renderConnections(person);
  }

  nodeEls.forEach((el) => {
    const slug = el.getAttribute('data-node');
    if (!slug) return;

    el.addEventListener('click', () => selectNode(slug));
    el.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        selectNode(slug);
      }
    });
  });

  resetBtn?.addEventListener('click', () => {
    resetGraph();
    if (nodes[0]) selectNode(nodes[0].slug);
  });

  graphSvg?.addEventListener('click', (event) => {
    if (event.target === graphSvg) {
      resetGraph();
    }
  });

  settleLayout();

  if (nodes[0]) {
    selectNode(nodes[0].slug);
  }
</script>
