---
import Layout from '../layouts/Layout.astro';
import { categoryOrder, people, type PersonCategory } from '../data/people';
import semanticGraph from '../data/people-graph.json';

type SemanticNode = {
  source: string;
  wikiTitle: string | null;
  wikiUrl: string | null;
  summary: string;
  graphWeight: number;
};

interface Research {
  slug: string;
  name: string;
  realName: string | null;
  oneLine?: string;
  bio?: string;
  topics?: string[];
  style?: string;
  notable?: string[];
  associatedWith?: string[];
  sources?: string[];
}

const semanticNodes = semanticGraph.nodes as Record<
  string,
  SemanticNode | undefined
>;

const researchModules = import.meta.glob<Research>(
  '../../data/people-research/*.json',
  { eager: true, import: 'default' },
);
const researchMap: Record<string, Research> = {};
for (const mod of Object.values(researchModules)) {
  if (mod?.slug) researchMap[mod.slug] = mod;
}

const categoryMeta: Record<
  PersonCategory,
  {
    label: string;
    blurb: string;
    cardClass: string;
    chipClass: string;
  }
> = {
  dev: {
    label: 'Dev / Software',
    blurb: 'tooling, programming taste, systems, and internet dev culture',
    cardClass: 'border-fox/20 bg-fox/[0.03]',
    chipClass: 'border-fox/25 bg-fox/[0.08] text-heading hover:bg-fox/[0.14]',
  },
  science: {
    label: 'Math / Science / Engineering',
    blurb: 'channels that make hard things feel intuitive instead of distant',
    cardClass: 'border-sky-500/20 bg-sky-500/[0.03]',
    chipClass:
      'border-sky-500/25 bg-sky-500/[0.08] text-heading hover:bg-sky-500/[0.14]',
  },
  hardware: {
    label: 'Hardware / Maker / Tech',
    blurb: 'pcs, hardware reviews, clean builds, and hands-on making',
    cardClass: 'border-emerald-500/20 bg-emerald-500/[0.03]',
    chipClass:
      'border-emerald-500/25 bg-emerald-500/[0.08] text-heading hover:bg-emerald-500/[0.14]',
  },
  swimming: {
    label: 'Swimming / Sport',
    blurb: 'people i watch for race craft, speed, consistency, and standards',
    cardClass: 'border-cyan-500/20 bg-cyan-500/[0.03]',
    chipClass:
      'border-cyan-500/25 bg-cyan-500/[0.08] text-heading hover:bg-cyan-500/[0.14]',
  },
  games: {
    label: 'Games / Internet',
    blurb: 'game design, minecraft orbit, and internet chaos',
    cardClass: 'border-violet-500/20 bg-violet-500/[0.03]',
    chipClass:
      'border-violet-500/25 bg-violet-500/[0.08] text-heading hover:bg-violet-500/[0.14]',
  },
  creative: {
    label: 'Film / Creative',
    blurb: 'editing, production, storytelling, and polished creator craft',
    cardClass: 'border-amber-500/20 bg-amber-500/[0.03]',
    chipClass:
      'border-amber-500/25 bg-amber-500/[0.08] text-heading hover:bg-amber-500/[0.14]',
  },
  chess: {
    label: 'Chess',
    blurb: 'competitive thinking, explanation, and pattern recognition',
    cardClass: 'border-red-500/20 bg-red-500/[0.03]',
    chipClass:
      'border-red-500/25 bg-red-500/[0.08] text-heading hover:bg-red-500/[0.14]',
  },
  comedy: {
    label: 'Comedy / Entertainment',
    blurb: 'stuff that is just fun, sharp, or entertainingly unhinged',
    cardClass: 'border-zinc-500/20 bg-zinc-500/[0.03]',
    chipClass:
      'border-zinc-500/25 bg-zinc-500/[0.08] text-heading hover:bg-zinc-500/[0.14]',
  },
};

const grouped = Object.fromEntries(
  categoryOrder.map((category) => [
    category,
    people
      .filter((person) => person.category === category)
      .sort((a, b) => b.weight - a.weight || a.name.localeCompare(b.name)),
  ]),
) as Record<PersonCategory, typeof people>;

const graphColors: Record<PersonCategory, string> = {
  dev: '#e8702a',
  science: '#40b8ff',
  hardware: '#119b74',
  swimming: '#16b8d8',
  games: '#6f4bd6',
  creative: '#c88a13',
  chess: '#d84848',
  comedy: '#686874',
};

const categoryCenters: Record<PersonCategory, { x: number; y: number }> = {
  dev: { x: 210, y: 160 },
  science: { x: 500, y: 120 },
  hardware: { x: 790, y: 170 },
  swimming: { x: 160, y: 450 },
  games: { x: 425, y: 500 },
  creative: { x: 680, y: 450 },
  chess: { x: 905, y: 420 },
  comedy: { x: 560, y: 315 },
};

const graphNodes = categoryOrder.flatMap((category) => {
  const members = grouped[category];
  const center = categoryCenters[category];

  return members.map((person, index) => {
    const angle = (Math.PI * 2 * index) / Math.max(members.length, 1);
    const ring = 42 + Math.floor(index / 5) * 38 + (5 - person.weight) * 6;
    const driftX = Math.sin(index * 1.7) * 12;
    const driftY = Math.cos(index * 1.3) * 10;
    const x = center.x + Math.cos(angle) * ring + driftX;
    const y = center.y + Math.sin(angle) * ring + driftY;

    return {
      ...person,
      semantic: semanticNodes[person.slug],
      research: researchMap[person.slug] || null,
      x,
      y,
      visualWeight: Math.max(
        person.weight,
        Math.round(
          (person.weight +
            (semanticNodes[person.slug]?.graphWeight || person.weight)) /
            2,
        ),
      ),
      color: graphColors[category],
    };
  });
});

const slugSet = new Set(graphNodes.map((node) => node.slug));

const explicitEdges = new Set<string>();
const graphEdges: Array<{
  source: string;
  target: string;
  inferred: boolean;
  score?: number;
}> = [];

for (const person of graphNodes) {
  for (const target of person.connections || []) {
    if (!slugSet.has(target)) continue;
    const [a, b] = [person.slug, target].sort();
    const key = `${a}:${b}`;
    if (explicitEdges.has(key)) continue;
    explicitEdges.add(key);
    graphEdges.push({ source: a, target: b, inferred: false });
  }
}

for (const edge of semanticGraph.semanticEdges) {
  const key = [edge.source, edge.target].sort().join(':');
  if (explicitEdges.has(key)) continue;
  if (!slugSet.has(edge.source) || !slugSet.has(edge.target)) continue;
  graphEdges.push({
    source: edge.source,
    target: edge.target,
    inferred: true,
    score: edge.score,
  });
}
---

<Layout
  title="People | Semyon Fox"
  description="Interesting people, channels, and internet rabbit holes I keep coming back to."
>
  <section class="pt-20 pb-16 md:pt-28">
    <h1 class="type-page-title mb-3">Interesting People/Videos</h1>
    <p class="type-body mb-4">
      some of my favorite content creators and internet people
    </p>
    <p class="type-caption max-w-2xl">
      weight roughly means how central they are to my feed, interests, or
      thinking. solid links are direct connections i care about; faint links are
      inferred from semantic similarity using embedded wiki or fallback profile
      text. this should feel more like a colored obsidian graph than a rigid
      category diagram.
    </p>
  </section>

  <section class="pb-16">
    <div class="flex items-center gap-3 mb-6">
      <span class="type-kicker">signal map</span>
      <span class="type-caption">weighted nodes, clustered by interest</span>
    </div>

    <div
      class="grid xl:grid-cols-[2.15fr_minmax(300px,0.85fr)] 2xl:grid-cols-[2.3fr_minmax(320px,0.8fr)] gap-4"
    >
      <div
        class="hidden md:block bg-surface border border-heading/[0.06] rounded-bento p-3 md:p-4 overflow-hidden"
      >
        <svg
          id="people-graph"
          viewBox="0 0 1000 620"
          class="w-full h-auto select-none touch-none"
          style="outline: none;"
          aria-label="Graph of interesting people and creators"
        >
          <rect
            id="people-graph-bg"
            x="0"
            y="0"
            width="1000"
            height="620"
            fill="#151313"></rect>
          <g opacity="0.14">
            {
              Array.from({ length: 20 }).map((_, i) => (
                <line
                  x1={i * 50}
                  y1="0"
                  x2={i * 50}
                  y2="620"
                  stroke="#4a4e63"
                  stroke-width="0.6"
                />
              ))
            }
            {
              Array.from({ length: 13 }).map((_, i) => (
                <line
                  x1="0"
                  y1={i * 50}
                  x2="1000"
                  y2={i * 50}
                  stroke="#4a4e63"
                  stroke-width="0.6"
                />
              ))
            }
          </g>

          {
            graphEdges.map((edge, index) => {
              const source = graphNodes.find(
                (node) => node.slug === edge.source,
              )!;
              const target = graphNodes.find(
                (node) => node.slug === edge.target,
              )!;
              return (
                <line
                  x1={source.x}
                  y1={source.y}
                  x2={target.x}
                  y2={target.y}
                  stroke="#8c93b0"
                  stroke-opacity={edge.inferred ? '0.08' : '0.18'}
                  stroke-width={edge.inferred ? '0.7' : '1'}
                  data-edge-index={index}
                  data-edge-source={edge.source}
                  data-edge-target={edge.target}
                  data-edge-inferred={edge.inferred ? 'true' : 'false'}
                />
              );
            })
          }

          {
            graphNodes.map((person) => (
              <g
                data-node={person.slug}
                class="cursor-pointer transition-opacity focus:outline-none focus-visible:outline-none"
                tabindex="0"
                role="button"
                aria-label={`Select ${person.name}`}
                style="outline: none;"
              >
                <circle
                  data-node-glow={person.slug}
                  cx={person.x}
                  cy={person.y}
                  r={4 + person.visualWeight * 1.6}
                  fill={person.color}
                  fill-opacity="0.06"
                />
                <circle
                  data-node-ring={person.slug}
                  cx={person.x}
                  cy={person.y}
                  r={3 + person.visualWeight * 0.9}
                  fill="none"
                  stroke={person.color}
                  stroke-opacity="0"
                  stroke-width="1"
                />
                <circle
                  data-node-focus={person.slug}
                  cx={person.x}
                  cy={person.y}
                  r={4.5 + person.visualWeight * 0.95}
                  fill="none"
                  stroke={person.color}
                  stroke-opacity="0"
                  stroke-width="1.2"
                />
                <circle
                  data-node-core={person.slug}
                  cx={person.x}
                  cy={person.y}
                  r={0.9 + person.visualWeight * 0.9}
                  fill={person.color}
                />
                <text
                  data-label={person.slug}
                  x={person.x}
                  y={person.y + 18}
                  text-anchor="middle"
                  fill="#d8dbef"
                  font-size={person.weight >= 4 ? '12' : '11'}
                  opacity={person.weight >= 4 ? '0.45' : '0.25'}
                >
                  {person.name}
                </text>
              </g>
            ))
          }
        </svg>
      </div>

      <aside
        id="people-detail"
        class="bg-surface border border-heading/[0.06] rounded-bento p-5"
      >
        <div id="people-empty-state">
          <p class="type-micro uppercase mb-3">signal map</p>
          <p class="type-body mb-5 hidden md:block">
            click a node to read about a person and highlight their connections.
            scroll the directory below for a structured view.
          </p>
          <p class="type-body mb-5 md:hidden">
            the interactive graph opens on wider screens. on mobile, use the
            directory below; only the first section starts open.
          </p>
          <p class="type-micro uppercase mb-2.5">categories</p>
          <ul class="space-y-1.5">
            {
              categoryOrder.map((category) => (
                <li class="flex items-center gap-2.5 text-xs">
                  <span
                    class="w-2 h-2 rounded-full shrink-0"
                    style={`background:${graphColors[category]}`}
                  />
                  <span class="text-muted">{categoryMeta[category].label}</span>
                  <span class="text-dim ml-auto tabular-nums">
                    {grouped[category].length}
                  </span>
                </li>
              ))
            }
          </ul>
        </div>

        <div id="people-detail-content" class="hidden">
          <div class="flex items-center justify-between gap-3 mb-3">
            <p class="type-micro uppercase">selected node</p>
            <button
              id="graph-reset"
              type="button"
              class="text-dim text-[11px] hover:text-heading transition-colors"
            >
              clear
            </button>
          </div>
          <div class="flex items-start justify-between gap-4 mb-3">
            <div class="min-w-0">
              <h2 id="detail-name" class="type-section-title"></h2>
              <p
                id="detail-real-name"
                class="text-dim text-[11px] mt-0.5 hidden"
              >
              </p>
              <p id="detail-category" class="text-dim text-xs mt-1"></p>
            </div>
            <a
              id="detail-primary"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="shrink-0 border border-border text-muted text-xs px-3 py-1.5 rounded-lg hover:text-heading hover:border-muted transition-colors"
            >
              open
            </a>
          </div>

          <p id="detail-summary" class="type-body mb-4"></p>

          <div id="detail-tags" class="flex flex-wrap gap-1.5 mb-4"></div>

          <div class="space-y-3">
            <div>
              <p class="type-micro uppercase mb-2">links</p>
              <div id="detail-links" class="flex flex-wrap gap-2"></div>
            </div>

            <div>
              <p class="type-micro uppercase mb-2">nearby nodes</p>
              <div id="detail-connections" class="flex flex-wrap gap-2"></div>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="pb-16">
    <div class="flex items-center gap-3 mb-6">
      <span class="type-kicker">directory</span>
      <span class="type-caption">
        grouped entries with quick links out to content
      </span>
    </div>

    <div class="space-y-3">
      {
        categoryOrder.map((category) => (
          <details
            open={category === 'dev'}
            class="people-cat bg-surface border border-heading/[0.06] rounded-bento overflow-hidden"
          >
            <summary class="list-none cursor-pointer p-5 flex items-center gap-3 hover:bg-heading/[0.02] transition-colors">
              <span
                class="w-2.5 h-2.5 rounded-full shrink-0"
                style={`background:${graphColors[category]}`}
              />
              <div class="flex-1 min-w-0">
                <h2 class="type-panel-title">{categoryMeta[category].label}</h2>
                <p class="text-dim text-sm mt-0.5">
                  {categoryMeta[category].blurb}
                </p>
              </div>
              <span class="text-dim text-[11px] tabular-nums shrink-0">
                {grouped[category].length}
              </span>
              <svg
                class="people-chevron w-3 h-3 text-dim transition-transform shrink-0"
                viewBox="0 0 12 12"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M3 4.5L6 7.5L9 4.5"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </summary>

            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-3 px-5 pb-5">
              {grouped[category].map((person) => {
                const research = researchMap[person.slug];
                const hasExtras =
                  !!research &&
                  (!!research.bio ||
                    (research.topics && research.topics.length > 0) ||
                    (research.notable && research.notable.length > 0) ||
                    (research.associatedWith &&
                      research.associatedWith.length > 0));
                const blurb = research?.oneLine || person.summary;
                return (
                  <article class="bg-bg/40 border border-heading/[0.06] rounded-bento p-4 hover:border-heading/10 transition-colors flex flex-col">
                    <div class="flex items-start justify-between gap-3 mb-2">
                      <div class="min-w-0">
                        <h3 class="type-small-title">{person.name}</h3>
                        {research?.realName && (
                          <p class="text-dim text-xs mt-0.5">
                            {research.realName}
                          </p>
                        )}
                      </div>
                      <a
                        href={person.links.primary}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="shrink-0 border border-border text-muted text-xs px-2.5 py-1 rounded hover:text-heading hover:border-muted transition-colors"
                      >
                        open
                      </a>
                    </div>

                    <p class="text-muted text-sm leading-relaxed mb-3">
                      {blurb}
                    </p>

                    <div class="flex flex-wrap gap-1 mb-3">
                      {person.tags.slice(0, 3).map((tag) => (
                        <span class="bg-border px-1.5 py-0.5 rounded text-xs text-muted">
                          {tag}
                        </span>
                      ))}
                    </div>

                    {hasExtras && (
                      <details class="people-more mt-auto">
                        <summary class="list-none cursor-pointer text-fox/80 text-xs hover:text-fox transition-colors select-none">
                          <span class="people-more-label-closed">
                            read more
                          </span>
                          <span class="people-more-label-open">show less</span>
                        </summary>
                        <div class="mt-3 space-y-3 text-xs text-muted leading-relaxed">
                          {research.bio && <p>{research.bio}</p>}
                          {research.topics && research.topics.length > 0 && (
                            <div>
                              <p class="text-dim uppercase text-[9px] mb-1.5">
                                topics
                              </p>
                              <div class="flex flex-wrap gap-1">
                                {research.topics.slice(0, 8).map((t) => (
                                  <span class="bg-border px-1.5 py-0.5 rounded text-xs">
                                    {t}
                                  </span>
                                ))}
                              </div>
                            </div>
                          )}
                          {research.notable && research.notable.length > 0 && (
                            <div>
                              <p class="text-dim uppercase text-[9px] mb-1.5">
                                notable
                              </p>
                              <ul class="space-y-0.5 list-disc list-inside marker:text-dim">
                                {research.notable.slice(0, 5).map((n) => (
                                  <li class="text-muted">{n}</li>
                                ))}
                              </ul>
                            </div>
                          )}
                          {research.associatedWith &&
                            research.associatedWith.length > 0 && (
                              <div>
                                <p class="text-dim uppercase text-[9px] mb-1.5">
                                  associated
                                </p>
                                <p class="text-muted">
                                  {research.associatedWith.join(', ')}
                                </p>
                              </div>
                            )}
                        </div>
                      </details>
                    )}
                  </article>
                );
              })}
            </div>
          </details>
        ))
      }
    </div>
  </section>
</Layout>

<style is:global>
  .people-cat > summary::-webkit-details-marker {
    display: none;
  }
  .people-more > summary::-webkit-details-marker {
    display: none;
  }
  .people-cat[open] .people-chevron {
    transform: rotate(180deg);
  }
  .people-more .people-more-label-open {
    display: none;
  }
  .people-more[open] .people-more-label-closed {
    display: none;
  }
  .people-more[open] .people-more-label-open {
    display: inline;
  }
</style>

<script
  is:inline
  define:vars={{
    people: graphNodes,
    connections: graphEdges,
    categoryMeta,
    categoryCenters,
  }}
>
  const nodes = people;
  const edgeList = connections;
  const nodeEls = Array.from(document.querySelectorAll('[data-node]'));
  const labelEls = Array.from(document.querySelectorAll('[data-label]'));
  const edgeEls = Array.from(
    document.querySelectorAll('[data-edge-source][data-edge-target]'),
  );
  const graphSvg = document.getElementById('people-graph');
  const nodeGlows = new Map(
    nodes.map((node) => [
      node.slug,
      document.querySelector(`[data-node-glow="${node.slug}"]`),
    ]),
  );
  const nodeRings = new Map(
    nodes.map((node) => [
      node.slug,
      document.querySelector(`[data-node-ring="${node.slug}"]`),
    ]),
  );
  const nodeFocuses = new Map(
    nodes.map((node) => [
      node.slug,
      document.querySelector(`[data-node-focus="${node.slug}"]`),
    ]),
  );
  const nodeCores = new Map(
    nodes.map((node) => [
      node.slug,
      document.querySelector(`[data-node-core="${node.slug}"]`),
    ]),
  );

  const detailName = document.getElementById('detail-name');
  const detailRealName = document.getElementById('detail-real-name');
  const detailCategory = document.getElementById('detail-category');
  const detailSummary = document.getElementById('detail-summary');
  const detailPrimary = document.getElementById('detail-primary');
  const detailTags = document.getElementById('detail-tags');
  const detailLinks = document.getElementById('detail-links');
  const detailConnections = document.getElementById('detail-connections');
  const detailContent = document.getElementById('people-detail-content');
  const emptyState = document.getElementById('people-empty-state');
  const resetBtn = document.getElementById('graph-reset');
  const graphBackground = document.getElementById('people-graph-bg');

  function showEmpty() {
    detailContent?.classList.add('hidden');
    emptyState?.classList.remove('hidden');
  }

  function showDetail() {
    emptyState?.classList.add('hidden');
    detailContent?.classList.remove('hidden');
  }

  const nodeMap = new Map(nodes.map((node) => [node.slug, node]));
  const positionMap = new Map(
    nodes.map((node) => [
      node.slug,
      {
        x: node.x,
        y: node.y,
        vx: 0,
        vy: 0,
      },
    ]),
  );
  const width = 1000;
  const height = 620;
  const padding = 24;
  const edgeBaseColor = '#8c93b0';
  const defaultView = { x: 0, y: 0, width, height };
  const currentView = { ...defaultView };
  let pointerState = null;
  let dragMoved = false;

  const linkOrder = [
    'youtube',
    'x',
    'github',
    'linkedin',
    'website',
    'primary',
  ];
  const linkLabels = {
    youtube: 'youtube',
    x: 'x',
    github: 'github',
    linkedin: 'linkedin',
    website: 'site',
    primary: 'open',
  };

  function applyViewBox() {
    graphSvg?.setAttribute(
      'viewBox',
      `${currentView.x} ${currentView.y} ${currentView.width} ${currentView.height}`,
    );
  }

  function clampView() {
    if (currentView.width >= width) {
      currentView.x = 0;
      currentView.width = width;
    } else {
      currentView.x = Math.max(
        0,
        Math.min(width - currentView.width, currentView.x),
      );
    }

    if (currentView.height >= height) {
      currentView.y = 0;
      currentView.height = height;
    } else {
      currentView.y = Math.max(
        0,
        Math.min(height - currentView.height, currentView.y),
      );
    }
  }

  function resetViewBox() {
    currentView.x = defaultView.x;
    currentView.y = defaultView.y;
    currentView.width = defaultView.width;
    currentView.height = defaultView.height;
    applyViewBox();
  }

  function eventToSvgPoint(event) {
    if (!graphSvg) return { x: 0, y: 0 };
    const rect = graphSvg.getBoundingClientRect();
    const relX = (event.clientX - rect.left) / rect.width;
    const relY = (event.clientY - rect.top) / rect.height;
    return {
      x: currentView.x + relX * currentView.width,
      y: currentView.y + relY * currentView.height,
    };
  }

  function renderLinks(person) {
    if (!detailLinks) return;
    detailLinks.innerHTML = '';

    const seen = new Set();

    for (const key of linkOrder) {
      const href = person.links?.[key];
      if (!href || seen.has(href)) continue;
      seen.add(href);

      const a = document.createElement('a');
      a.href = href;
      a.target = '_blank';
      a.rel = 'noopener noreferrer';
      a.className =
        'border border-border text-muted text-[11px] px-2.5 py-1 rounded hover:text-heading hover:border-muted transition-colors';
      a.textContent = linkLabels[key];
      detailLinks.appendChild(a);
    }
  }

  function renderConnections(person) {
    if (!detailConnections) return;
    detailConnections.innerHTML = '';

    const nearby = new Set(person.connections || []);
    for (const edge of edgeList) {
      if (edge.source === person.slug) nearby.add(edge.target);
      if (edge.target === person.slug) nearby.add(edge.source);
    }

    for (const slug of nearby) {
      const target = nodeMap.get(slug);
      if (!target) continue;

      const button = document.createElement('button');
      button.type = 'button';
      button.className =
        'bg-border px-2 py-0.5 rounded text-[11px] text-muted hover:text-heading transition-colors';
      button.textContent = target.name;
      button.addEventListener('click', () => selectNode(slug));
      detailConnections.appendChild(button);
    }
  }

  function renderTags(person) {
    if (!detailTags) return;
    detailTags.innerHTML = '';

    for (const tag of person.tags || []) {
      const span = document.createElement('span');
      span.className = 'bg-border px-2 py-0.5 rounded text-[11px] text-muted';
      span.textContent = tag;
      detailTags.appendChild(span);
    }
  }

  function resetGraph() {
    nodeEls.forEach((el) => {
      el.style.opacity = '1';
    });

    edgeEls.forEach((el) => {
      const inferred = el.getAttribute('data-edge-inferred') === 'true';
      el.style.opacity = inferred ? '0.08' : '0.18';
      el.setAttribute('stroke', edgeBaseColor);
      el.setAttribute('stroke-width', inferred ? '0.7' : '1');
    });

    labelEls.forEach((el) => {
      const slug = el.getAttribute('data-label');
      const person = slug ? nodeMap.get(slug) : null;
      if (!person) return;
      el.style.opacity = person.weight >= 4 ? '0.45' : '0.25';
    });

    nodes.forEach((node) => {
      const glow = nodeGlows.get(node.slug);
      const ring = nodeRings.get(node.slug);
      const focus = nodeFocuses.get(node.slug);
      const core = nodeCores.get(node.slug);
      if (glow) {
        glow.setAttribute('r', String(4 + node.visualWeight * 1.6));
        glow.setAttribute('fill-opacity', '0.06');
      }
      if (ring) {
        ring.setAttribute('r', String(3 + node.visualWeight * 0.9));
        ring.setAttribute('stroke-opacity', '0');
      }
      if (focus) {
        focus.setAttribute('r', String(4.5 + node.visualWeight * 0.95));
        focus.setAttribute('stroke-opacity', '0');
      }
      if (core) {
        core.setAttribute('r', String(0.9 + node.visualWeight * 0.9));
      }
    });
  }

  function tickLayout() {
    const entries = nodes.map((node) => ({
      node,
      pos: positionMap.get(node.slug),
    }));

    for (let i = 0; i < entries.length; i++) {
      for (let j = i + 1; j < entries.length; j++) {
        const a = entries[i];
        const b = entries[j];
        const dx = a.pos.x - b.pos.x;
        const dy = a.pos.y - b.pos.y;
        const distSq = dx * dx + dy * dy + 0.01;
        const dist = Math.sqrt(distSq);
        const force = 220 / distSq;
        const fx = (dx / dist) * force;
        const fy = (dy / dist) * force;
        a.pos.vx += fx;
        a.pos.vy += fy;
        b.pos.vx -= fx;
        b.pos.vy -= fy;
      }
    }

    for (const edge of edgeList) {
      const source = positionMap.get(edge.source);
      const target = positionMap.get(edge.target);
      if (!source || !target) continue;
      const dx = target.x - source.x;
      const dy = target.y - source.y;
      const dist = Math.sqrt(dx * dx + dy * dy) || 1;
      const desired = edge.inferred ? 85 : 60;
      const strength = edge.inferred ? 0.0025 : 0.006;
      const force = (dist - desired) * strength;
      const fx = (dx / dist) * force;
      const fy = (dy / dist) * force;
      source.vx += fx;
      source.vy += fy;
      target.vx -= fx;
      target.vy -= fy;
    }

    for (const { node, pos } of entries) {
      const anchor = categoryCenters[node.category];
      pos.vx += (anchor.x - pos.x) * 0.0005;
      pos.vy += (anchor.y - pos.y) * 0.0005;
      pos.vx += (width / 2 - pos.x) * 0.00005;
      pos.vy += (height / 2 - pos.y) * 0.00005;
      pos.vx *= 0.88;
      pos.vy *= 0.88;
      pos.x = Math.max(padding, Math.min(width - padding, pos.x + pos.vx));
      pos.y = Math.max(padding, Math.min(height - padding, pos.y + pos.vy));
    }
  }

  function renderLayout() {
    for (const node of nodes) {
      const pos = positionMap.get(node.slug);
      const group = document.querySelector(`[data-node="${node.slug}"]`);
      const glow = nodeGlows.get(node.slug);
      const ring = nodeRings.get(node.slug);
      const focus = nodeFocuses.get(node.slug);
      const core = nodeCores.get(node.slug);
      const label = document.querySelector(`[data-label="${node.slug}"]`);
      if (!pos || !group || !glow || !ring || !focus || !core || !label)
        continue;

      glow.setAttribute('cx', pos.x);
      glow.setAttribute('cy', pos.y);
      ring.setAttribute('cx', pos.x);
      ring.setAttribute('cy', pos.y);
      focus.setAttribute('cx', pos.x);
      focus.setAttribute('cy', pos.y);
      core.setAttribute('cx', pos.x);
      core.setAttribute('cy', pos.y);
      label.setAttribute('x', pos.x);
      label.setAttribute('y', pos.y + 18);
    }

    edgeEls.forEach((el) => {
      const source = positionMap.get(el.getAttribute('data-edge-source'));
      const target = positionMap.get(el.getAttribute('data-edge-target'));
      if (!source || !target) return;
      el.setAttribute('x1', source.x);
      el.setAttribute('y1', source.y);
      el.setAttribute('x2', target.x);
      el.setAttribute('y2', target.y);
    });
  }

  function settleLayout(iterations = 180) {
    for (let i = 0; i < iterations; i++) {
      tickLayout();
    }
    renderLayout();
  }

  function selectNode(slug) {
    const person = nodeMap.get(slug);
    if (!person) return;

    const connected = new Set([slug]);
    for (const edge of edgeList) {
      if (edge.source === slug) connected.add(edge.target);
      if (edge.target === slug) connected.add(edge.source);
    }

    nodeEls.forEach((el) => {
      const active = connected.has(el.getAttribute('data-node') || '');
      el.style.opacity = active ? '1' : '0.24';
    });

    edgeEls.forEach((el) => {
      const source = el.getAttribute('data-edge-source');
      const target = el.getAttribute('data-edge-target');
      const active = source === slug || target === slug;
      const inferred = el.getAttribute('data-edge-inferred') === 'true';
      const activeColor =
        source === slug
          ? person.color
          : target === slug
            ? person.color
            : edgeBaseColor;
      el.style.opacity = active ? '0.72' : inferred ? '0.05' : '0.08';
      el.setAttribute('stroke', active ? activeColor : edgeBaseColor);
      el.setAttribute('stroke-width', active ? '1.8' : inferred ? '0.7' : '1');
    });

    labelEls.forEach((el) => {
      const labelSlug = el.getAttribute('data-label') || '';
      const active = connected.has(labelSlug);
      el.style.opacity = active ? '0.92' : '0.02';
    });

    nodes.forEach((node) => {
      const glow = nodeGlows.get(node.slug);
      const ring = nodeRings.get(node.slug);
      const focus = nodeFocuses.get(node.slug);
      const core = nodeCores.get(node.slug);
      const isSelected = node.slug === slug;
      const isNeighbor = connected.has(node.slug) && !isSelected;
      const isActive = isSelected || isNeighbor;
      if (glow) {
        glow.setAttribute(
          'r',
          String(
            isActive
              ? 8 + node.visualWeight * 2.1
              : 4 + node.visualWeight * 1.6,
          ),
        );
        glow.setAttribute('fill-opacity', isActive ? '0.16' : '0.06');
      }
      if (ring) {
        ring.setAttribute(
          'r',
          String(
            isActive
              ? 3 + node.visualWeight * 0.9
              : 3 + node.visualWeight * 0.9,
          ),
        );
        ring.setAttribute('stroke-opacity', isActive ? '0.4' : '0');
      }
      if (focus) {
        focus.setAttribute('stroke-opacity', isSelected ? '0.7' : '0');
      }
      if (core) {
        core.setAttribute(
          'r',
          String(
            isActive
              ? 1.3 + node.visualWeight * 0.95
              : 0.9 + node.visualWeight * 0.9,
          ),
        );
      }
    });

    showDetail();

    if (detailName) detailName.textContent = person.name;
    if (detailRealName) {
      if (person.research?.realName) {
        detailRealName.textContent = person.research.realName;
        detailRealName.classList.remove('hidden');
      } else {
        detailRealName.textContent = '';
        detailRealName.classList.add('hidden');
      }
    }
    if (detailCategory) {
      detailCategory.textContent = `${categoryMeta[person.category].label} · signal ${person.weight}/5 · graph ${person.semantic?.graphWeight || person.weight}/5`;
    }
    if (detailSummary) {
      detailSummary.textContent = person.research?.oneLine || person.summary;
    }
    if (detailPrimary) detailPrimary.href = person.links.primary;

    renderTags(person);
    renderLinks(person);
    renderConnections(person);
  }

  nodeEls.forEach((el) => {
    const slug = el.getAttribute('data-node');
    if (!slug) return;

    el.addEventListener('click', (event) => {
      event.stopPropagation();
      selectNode(slug);
    });
    el.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        selectNode(slug);
      }
    });
  });

  resetBtn?.addEventListener('click', () => {
    resetViewBox();
    resetGraph();
    showEmpty();
  });

  graphSvg?.addEventListener(
    'wheel',
    (event) => {
      event.preventDefault();
      const point = eventToSvgPoint(event);
      const zoomFactor = event.deltaY < 0 ? 0.9 : 1.1;
      const nextWidth = Math.max(
        320,
        Math.min(width, currentView.width * zoomFactor),
      );
      const scale = nextWidth / currentView.width;
      const nextHeight = currentView.height * scale;
      const relX = (point.x - currentView.x) / currentView.width;
      const relY = (point.y - currentView.y) / currentView.height;

      currentView.x = point.x - relX * nextWidth;
      currentView.y = point.y - relY * nextHeight;
      currentView.width = nextWidth;
      currentView.height = nextHeight;
      clampView();
      applyViewBox();
    },
    { passive: false },
  );

  graphSvg?.addEventListener('pointerdown', (event) => {
    if (!graphSvg) return;
    const onNode =
      event.target instanceof Element && event.target.closest('[data-node]');
    if (onNode) return;
    pointerState = {
      x: event.clientX,
      y: event.clientY,
      viewX: currentView.x,
      viewY: currentView.y,
    };
    dragMoved = false;
    graphSvg.setPointerCapture?.(event.pointerId);
  });

  graphSvg?.addEventListener('pointermove', (event) => {
    if (!graphSvg || !pointerState) return;
    const rect = graphSvg.getBoundingClientRect();
    const dx =
      ((event.clientX - pointerState.x) / rect.width) * currentView.width;
    const dy =
      ((event.clientY - pointerState.y) / rect.height) * currentView.height;
    if (Math.abs(dx) > 2 || Math.abs(dy) > 2) {
      dragMoved = true;
    }
    if (!dragMoved) return;
    currentView.x = pointerState.viewX - dx;
    currentView.y = pointerState.viewY - dy;
    clampView();
    applyViewBox();
  });

  graphSvg?.addEventListener('pointerup', (event) => {
    if (pointerState) {
      try {
        graphSvg.releasePointerCapture?.(event.pointerId);
      } catch {}
    }
    setTimeout(() => {
      dragMoved = false;
    }, 0);
    pointerState = null;
  });

  graphSvg?.addEventListener('pointerleave', () => {
    pointerState = null;
  });

  graphSvg?.addEventListener('click', (event) => {
    if (
      !dragMoved &&
      (event.target === graphSvg || event.target === graphBackground)
    ) {
      resetGraph();
      showEmpty();
    }
  });

  applyViewBox();
  settleLayout();
</script>
