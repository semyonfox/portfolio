---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout
  title={`${post.data.title} | Semyon Fox`}
  description={post.data.description}
>
  <article class="pt-20 pb-16 md:pt-28 max-w-[65ch]">
    <a
      href="/blog"
      class="text-dim text-xs hover:text-muted transition-colors mb-6 inline-block"
      >&larr; back to blog</a
    >
    <p class="text-dim text-xs mb-3">
      {
        new Date(post.data.date).toLocaleDateString('en-IE', {
          day: 'numeric',
          month: 'long',
          year: 'numeric',
        })
      }
      &middot; {post.data.author}
    </p>
    {
      post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mb-4">
          {post.data.tags.map((tag) => (
            <span class="bg-border px-2 py-0.5 rounded text-[11px] text-muted">
              {tag}
            </span>
          ))}
        </div>
      )
    }
    <h1 class="type-page-title mb-8">{post.data.title}</h1>
    <div id="post-content" class="type-prose">
      <Content />
    </div>
  </article>
</Layout>
