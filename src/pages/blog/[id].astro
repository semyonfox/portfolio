---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout
  title={`${post.data.title} | Semyon Fox`}
  description={post.data.description}
>
  <article class="pt-20 pb-16 md:pt-28 max-w-2xl">
    <a
      href="/blog"
      class="text-dim text-xs hover:text-muted transition-colors mb-6 inline-block"
      >&larr; back to blog</a
    >
    <p class="text-dim text-xs mb-3">
      {
        new Date(post.data.date).toLocaleDateString('en-IE', {
          day: 'numeric',
          month: 'long',
          year: 'numeric',
        })
      }
      &middot; {post.data.author}
    </p>
    <div class="flex items-center gap-4 mb-8">
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight">
        {post.data.title}
      </h1>
      <button
        id="read-aloud"
        class="shrink-0 border border-border text-muted text-xs px-3 py-1.5 rounded-lg hover:text-heading hover:border-muted transition-colors"
        aria-label="Read post aloud"
        aria-pressed="false"
      >
        read aloud
      </button>
    </div>
    <div
      id="post-content"
      class="prose prose-invert prose-sm max-w-none text-muted leading-relaxed space-y-4 [&>p]:text-muted [&>h2]:text-heading [&>h2]:text-xl [&>h2]:font-bold [&>h2]:mt-8 [&>h2]:mb-4 [&>h3]:text-heading [&>h3]:font-semibold [&>h3]:mt-6 [&>h3]:mb-3"
    >
      <Content />
    </div>
  </article>
</Layout>

<script>
  const btn = document.getElementById('read-aloud');
  const content = document.getElementById('post-content');
  const synth = window.speechSynthesis;

  if (btn && content && synth) {
    let speaking = false;

    btn.addEventListener('click', () => {
      if (speaking) {
        synth.cancel();
        btn.textContent = 'read aloud';
        btn.setAttribute('aria-pressed', 'false');
        speaking = false;
        return;
      }

      const text = (content.textContent || '').trim();
      if (!text) return;

      const utter = new SpeechSynthesisUtterance(text);
      utter.onend = utter.onerror = () => {
        btn.textContent = 'read aloud';
        btn.setAttribute('aria-pressed', 'false');
        speaking = false;
      };

      btn.textContent = 'stop';
      btn.setAttribute('aria-pressed', 'true');
      speaking = true;
      synth.speak(utter);
    });
  }
</script>
