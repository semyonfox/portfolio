---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout
  title={`${post.data.title} | Semyon Fox`}
  description={post.data.description}
>
  <article class="pt-20 pb-16 md:pt-28 max-w-2xl">
    <a
      href="/blog"
      class="text-dim text-xs hover:text-muted transition-colors mb-6 inline-block"
      >&larr; back to blog</a
    >
    <p class="text-dim text-xs mb-3">
      {
        new Date(post.data.date).toLocaleDateString('en-IE', {
          day: 'numeric',
          month: 'long',
          year: 'numeric',
        })
      }
      &middot; {post.data.author}
    </p>
    {
      post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mb-4">
          {post.data.tags.map((tag) => (
            <span class="bg-border px-2 py-0.5 rounded text-[11px] text-muted">
              {tag}
            </span>
          ))}
        </div>
      )
    }
    <div class="flex items-center gap-4 mb-8">
      <h1 class="type-page-title">{post.data.title}</h1>
      <button
        id="read-aloud"
        class="shrink-0 border border-border text-muted text-xs px-3 py-1.5 rounded-lg hover:text-heading hover:border-muted transition-colors"
        aria-label="Read post aloud"
        aria-pressed="false"
      >
        read aloud
      </button>
    </div>
    <div id="post-content" class="type-prose">
      <Content />
    </div>
  </article>
</Layout>

<script>
  const btn = document.getElementById('read-aloud');
  const content = document.getElementById('post-content');
  const synth = window.speechSynthesis;

  if (btn && content && synth) {
    let speaking = false;

    btn.addEventListener('click', () => {
      if (speaking) {
        synth.cancel();
        btn.textContent = 'read aloud';
        btn.setAttribute('aria-pressed', 'false');
        speaking = false;
        return;
      }

      const text = (content.textContent || '').trim();
      if (!text) return;

      const utter = new SpeechSynthesisUtterance(text);
      utter.onend = utter.onerror = () => {
        btn.textContent = 'read aloud';
        btn.setAttribute('aria-pressed', 'false');
        speaking = false;
      };

      btn.textContent = 'stop';
      btn.setAttribute('aria-pressed', 'true');
      speaking = true;
      synth.speak(utter);
    });
  }
</script>
