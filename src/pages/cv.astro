---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="CV | Semyon Fox"
  description="Semyon Fox - CS student, full-stack developer, homelab enthusiast."
>
  <section class="pt-20 pb-16 md:pt-28 max-w-3xl">
    <div
      class="flex flex-col gap-4 mb-1 sm:flex-row sm:items-center sm:justify-between"
    >
      <h1 class="type-page-title">Semyon Fox</h1>
      <div
        class="group relative flex shrink-0 items-stretch text-xs"
        data-cv-download
        data-cv-format="pdf"
      >
        <a
          href="/cv.pdf"
          download="SEMYON_FOX_CV.pdf"
          class="inline-flex min-h-10 min-w-32 items-center justify-between gap-3 rounded-l-lg border border-border border-r-0 bg-surface/60 px-3.5 py-2 font-medium tracking-[0.01em] text-heading transition-colors group-hover:border-muted group-hover:bg-heading/[0.03]"
          aria-label="Download CV as PDF"
          data-cv-download-link
        >
          <span>Download</span>
          <span class="type-micro font-semibold uppercase tracking-[0.08em]"
            >PDF</span
          >
        </a>
        <button
          type="button"
          class="inline-flex min-h-10 w-10 items-center justify-center rounded-r-lg border border-border bg-surface/60 text-muted transition-colors group-hover:border-muted group-hover:bg-heading/[0.03] hover:text-heading"
          aria-label="Choose CV format"
          aria-expanded="false"
          data-cv-menu-toggle
        >
          <svg
            aria-hidden="true"
            class="size-3.5"
            viewBox="0 0 16 16"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M4 6L8 10L12 6"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
        <div
          class="absolute inset-x-0 top-full z-20 mt-2 hidden overflow-hidden rounded-lg border border-border bg-surface shadow-xl shadow-black/20"
          data-cv-menu
        >
          <button
            type="button"
            class="flex min-h-10 w-full items-center justify-between gap-3 px-3.5 py-2 text-left text-xs font-medium tracking-[0.01em] text-heading transition-colors hover:bg-heading/[0.04]"
            data-cv-option="tex"
          >
            <span>TeX source</span>
            <span class="type-micro font-semibold uppercase tracking-[0.08em]"
              >TEX</span
            >
          </button>
        </div>
      </div>
    </div>
    <p class="text-muted text-sm mb-2">Galway, Ireland</p>
    <div class="flex flex-wrap gap-3 text-xs text-muted mb-8">
      <a
        href="mailto:semyon.fox@gmail.com"
        class="hover:text-heading transition-colors">semyon.fox@gmail.com</a
      >
      <span class="text-dim">&middot;</span>
      <a href="https://semyon.ie" class="hover:text-heading transition-colors"
        >semyon.ie</a
      >
      <span class="text-dim">&middot;</span>
      <a
        href="https://github.com/semyonfox"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-heading transition-colors">github.com/semyonfox</a
      >
      <span class="text-dim">&middot;</span>
      <a
        href="https://www.linkedin.com/in/semyon-fox-968685249/"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-heading transition-colors">LinkedIn</a
      >
    </div>

    <p class="type-body italic mb-12">
      Builder, swimmer, filmmaker. Second-year Computer Science student at the
      University of Galway with First Class Honours in year 1. Auditor turned
      Treasurer of CompSoc, a 450+ member computing society. Builds React and
      Next.js frontends, Rust APIs, and self-hosted infrastructure.
    </p>

    <!-- technical skills -->
    <div class="mb-12">
      <h2 class="type-section-title mb-4">Technical Skills</h2>
      <div class="space-y-2 text-sm">
        <p>
          <span class="text-heading font-semibold">Languages:</span>
          <span class="text-muted"
            >JavaScript, TypeScript, Java, C, SQL, Python, Rust</span
          >
        </p>
        <p>
          <span class="text-heading font-semibold">Web:</span>
          <span class="text-muted"
            >React, Next.js, Astro, Node.js/Express, REST APIs, HTML/CSS,
            Tailwind CSS</span
          >
        </p>
        <p>
          <span class="text-heading font-semibold">Databases:</span>
          <span class="text-muted">PostgreSQL, TimescaleDB, MySQL, Redis</span>
        </p>
        <p>
          <span class="text-heading font-semibold">Infrastructure:</span>
          <span class="text-muted"
            >Docker, Jenkins CI/CD, Git/GitHub, Linux, Nginx, Cloudflare
            Workers, Tunnels, Zero Trust, AWS, Btrfs, NFS</span
          >
        </p>
      </div>
    </div>

    <!-- education -->
    <div class="mb-12">
      <h2 class="type-section-title mb-4">Education</h2>
      <div class="border-l border-border pl-6">
        <h3 class="type-panel-title font-bold">University of Galway</h3>
        <p class="text-muted text-sm">
          Bachelor of Science (Honours) in Computer Science and Information
          Technology &middot; Expected August 2028
        </p>
        <p class="text-muted text-sm mt-1">
          2nd Year &middot; <span class="text-heading font-semibold"
            >First Class Honours</span
          > (Year 1)
        </p>
        <p class="text-dim text-xs mt-2">
          Software Engineering, Database Systems, OOP (Java), Data Structures &
          Algorithms, Networks & Data Communication, Computer Systems &
          Organisation, Digital Security & Cryptography, Modelling, Discrete
          Mathematics, Linear Algebra, Statistics
        </p>
      </div>
    </div>

    <!-- honours -->
    <div class="mb-12">
      <h2 class="type-section-title mb-4">Honours & Awards</h2>
      <div class="space-y-4">
        <div class="bg-surface border border-heading/[0.06] rounded-bento p-4">
          <div class="flex justify-between items-start">
            <h3 class="type-small-title font-bold">
              Best Intervarsity Award - CompSoc "Capture the Flag"
            </h3>
            <span class="text-dim text-xs shrink-0 ml-4"
              >Mar 2025, Mar 2026</span
            >
          </div>
          <p class="text-muted text-sm mt-1">
            University of Galway Societies Awards 2025 and 2026; BICS National
            Society Award 2025, nominated again in 2026.
          </p>
        </div>
        <div class="bg-surface border border-heading/[0.06] rounded-bento p-4">
          <div class="flex justify-between items-start">
            <h3 class="type-small-title font-bold">
              Brian O Maoilchiarain Award
            </h3>
            <span class="text-dim text-xs shrink-0 ml-4">Jun 2024</span>
          </div>
          <p class="text-muted text-sm mt-1">
            Outstanding Student, Leaving Certificate year - Colaiste an
            Eachréidh
          </p>
        </div>
        <div class="bg-surface border border-heading/[0.06] rounded-bento p-4">
          <div class="flex justify-between items-start">
            <h3 class="type-small-title font-bold">STEM Award - GRETB</h3>
            <span class="text-dim text-xs shrink-0 ml-4">Jun 2024</span>
          </div>
          <p class="text-muted text-sm mt-1">
            Recognition for excellence in STEM subjects.
          </p>
        </div>
      </div>
    </div>

    <!-- projects -->
    <div class="mb-12">
      <h2 class="type-section-title mb-4">Key Projects</h2>
      <div class="space-y-4">
        <div class="bg-surface border border-heading/[0.06] rounded-bento p-4">
          <div class="flex justify-between items-start">
            <h3 class="type-small-title font-bold">OghmaNotes</h3>
            <span class="text-dim text-xs shrink-0 ml-4">MVP Deployed</span>
          </div>
          <p class="text-dim text-xs mt-1">
            Next.js, TypeScript, PostgreSQL, pgvector, Redis, AWS, Docker
          </p>
          <p class="text-muted text-sm mt-2">
            Markdown e-learning platform with RAG search, quizzing, FSRS spaced
            repetition, Canvas LMS import, PDF extraction, and embedding
            pipeline. Migrated from AWS to self-hosted on-prem to cut costs.
          </p>
        </div>
        <div class="bg-surface border border-heading/[0.06] rounded-bento p-4">
          <div class="flex justify-between items-start">
            <h3 class="type-small-title font-bold">Uisce</h3>
            <span class="text-dim text-xs shrink-0 ml-4"
              >Targeting Aug 2026</span
            >
          </div>
          <p class="text-dim text-xs mt-1">
            React 19, Node.js/Express, PostgreSQL, Redis, Docker, Jest
          </p>
          <p class="text-muted text-sm mt-2">
            Full-stack platform with role-based access for swimmers, coaches,
            and committee members. 58-table PostgreSQL schema covering
            attendance, meet results, training schedules, squad analytics, and
            equipment.
          </p>
        </div>
        <div class="bg-surface border border-heading/[0.06] rounded-bento p-4">
          <div class="flex justify-between items-start">
            <h3 class="type-small-title font-bold">Canvas MCP Server</h3>
            <span class="text-dim text-xs shrink-0 ml-4">Open Source</span>
          </div>
          <p class="text-dim text-xs mt-1">
            TypeScript, Model Context Protocol SDK, Zod
          </p>
          <p class="text-muted text-sm mt-2">
            MCP server exposing the full Canvas LMS REST API to AI assistants
            across 15 domains. Merged and normalised 12 open-source Canvas MCP
            projects.
          </p>
        </div>
        <div class="bg-surface border border-heading/[0.06] rounded-bento p-4">
          <div class="flex justify-between items-start">
            <h3 class="type-small-title font-bold">Irish Rail Data Pipeline</h3>
            <span class="text-dim text-xs shrink-0 ml-4">Running 24/7</span>
          </div>
          <p class="text-dim text-xs mt-1">
            Python, asyncio/aiohttp, TimescaleDB, Rust, axum, Docker
          </p>
          <p class="text-muted text-sm mt-2">
            Polls Irish Rail every 3 seconds, storing train positions and
            station data in TimescaleDB. Rust API serves a live map and
            delay-tracking dashboard.
          </p>
        </div>
        <div class="bg-surface border border-heading/[0.06] rounded-bento p-4">
          <div class="flex justify-between items-start">
            <h3 class="type-small-title font-bold">
              Home Lab & CI/CD Infrastructure
            </h3>
            <span class="text-dim text-xs shrink-0 ml-4">Ongoing</span>
          </div>
          <p class="text-dim text-xs mt-1">
            Docker, Jenkins, Nginx, Cloudflare Tunnels, Btrfs, NFS, Pi-hole
          </p>
          <p class="text-muted text-sm mt-2">
            Self-hosts 30+ services in 54 containers. Six Jenkins pipelines
            auto-deploy projects on GitHub push, with Cloudflare Zero Trust
            tunnels, internal Nginx reverse proxying, and GFS backups to NAS.
          </p>
        </div>
      </div>
      <a
        href="/projects"
        class="text-fox text-sm mt-3 inline-block hover:underline"
        >view all projects &rarr;</a
      >
    </div>

    <!-- work experience -->
    <div class="mb-12">
      <h2 class="type-section-title mb-4">Work Experience</h2>
      <div class="border-l border-border pl-6 space-y-6">
        <div>
          <h3 class="type-panel-title font-bold">Laptop Repair Technician</h3>
          <p class="text-muted text-sm">
            Cahill Computers, Athenry & Galway &middot; part-time, 8 months
          </p>
          <p class="text-dim text-sm mt-2">
            Hardware upgrades, repairs, diagnostics. System administration, OS
            installation, drive cloning.
          </p>
        </div>
        <div>
          <h3 class="type-panel-title font-bold">Work Experience Placements</h3>
          <p class="text-muted text-sm">Lapteck TY placement (2023)</p>
          <p class="text-dim text-sm mt-2">
            Hardware upgrades, screen and battery replacements, OS installation,
            drive cloning, and diagnostics.
          </p>
        </div>
      </div>
    </div>

    <!-- leadership -->
    <div class="mb-12">
      <h2 class="type-section-title mb-4">Leadership & Involvement</h2>
      <div class="border-l border-border pl-6">
        <h3 class="type-panel-title font-bold">CompSoc Treasurer</h3>
        <p class="text-muted text-sm">
          University of Galway Computer Society &middot; Nov 2024 - present
        </p>
        <p class="text-dim text-sm mt-2">
          Led 450+ member student society across finance, communications, and
          event strategy. Organised CompSoc CTF 2026 with 110+ participants,
          four corporate sponsors, and university grant funding. Reduced
          participant costs by 50%, increased event profit, and fixed CI/CD and
          JSX bugs on the compsoc.ie React/TypeScript frontend. Previously PR
          Officer and Auditor.
        </p>
      </div>
    </div>

    <!-- interests -->
    <div>
      <h2 class="type-section-title mb-4">Interests</h2>
      <p class="type-body">
        Competitive pool swimming with regular training and meets. Video
        production, colour grading, VFX, and editing in DaVinci Resolve.
        Woodworking and hand-built live-edge furniture.
      </p>
    </div>
  </section>

  <script>
    const wrapper = document.querySelector('[data-cv-download]');
    const link = wrapper?.querySelector('[data-cv-download-link]');
    const toggle = wrapper?.querySelector('[data-cv-menu-toggle]');
    const menu = wrapper?.querySelector('[data-cv-menu]');

    const downloads = {
      pdf: {
        href: '/cv.pdf',
        filename: 'SEMYON_FOX_CV.pdf',
        badge: 'PDF',
        optionTitle: 'PDF version',
      },
      tex: {
        href: '/cv.tex',
        filename: 'SEMYON_FOX_CV.tex',
        badge: 'TEX',
        optionTitle: 'TeX source',
      },
    };

    const renderDownloadLabel = (badge: string) =>
      `<span>Download</span><span class="type-micro font-semibold uppercase tracking-[0.08em]">${badge}</span>`;

    const renderOptionLabel = (format: 'pdf' | 'tex') => {
      const option = downloads[format];

      return `<span>${option.optionTitle}</span><span class="type-micro font-semibold uppercase tracking-[0.08em]">${option.badge}</span>`;
    };

    const setMenuOpen = (open: boolean) => {
      if (
        !(toggle instanceof HTMLButtonElement) ||
        !(menu instanceof HTMLElement)
      ) {
        return;
      }

      menu.classList.toggle('hidden', !open);
      toggle.setAttribute('aria-expanded', String(open));
    };

    const setFormat = (format: 'pdf' | 'tex') => {
      if (
        !(wrapper instanceof HTMLElement) ||
        !(link instanceof HTMLAnchorElement)
      ) {
        return;
      }

      const activeFormat = format === 'tex' ? 'tex' : 'pdf';
      const alternateFormat = activeFormat === 'pdf' ? 'tex' : 'pdf';
      const download = downloads[activeFormat];
      const option = menu?.querySelector('[data-cv-option]');

      wrapper.dataset.cvFormat = activeFormat;
      link.href = download.href;
      link.download = download.filename;
      link.setAttribute('aria-label', `Download CV as ${download.badge}`);
      link.innerHTML = renderDownloadLabel(download.badge);

      if (option instanceof HTMLButtonElement) {
        option.dataset.cvOption = alternateFormat;
        option.innerHTML = renderOptionLabel(alternateFormat);
      }
    };

    if (
      wrapper instanceof HTMLElement &&
      toggle instanceof HTMLButtonElement &&
      menu instanceof HTMLElement
    ) {
      toggle.addEventListener('click', () => {
        setMenuOpen(toggle.getAttribute('aria-expanded') !== 'true');
      });

      menu.addEventListener('click', (event) => {
        const option =
          event.target instanceof Element
            ? event.target.closest('[data-cv-option]')
            : null;

        if (option instanceof HTMLButtonElement) {
          setFormat(option.dataset.cvOption === 'pdf' ? 'pdf' : 'tex');
          setMenuOpen(false);
        }
      });

      document.addEventListener('click', (event) => {
        if (event.target instanceof Node && !wrapper.contains(event.target)) {
          setMenuOpen(false);
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          setMenuOpen(false);
        }
      });
    }
  </script>
</Layout>
