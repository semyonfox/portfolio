---
import Layout from '../layouts/Layout.astro';
import {
  cv,
  formatAwardDates,
  formatDate,
  formatModules,
  formatProjectStatus,
  formatStack,
  projectSupports,
  textFor,
} from '../data/cv';

const defaultDownload = cv.downloads[0];
const alternateDownload = cv.downloads[1];
const htmlProjects = cv.projects.filter((project) =>
  projectSupports(project, 'html'),
);
const previousLeadershipRoles = cv.leadership.roleHistory
  .slice(0, -1)
  .map((role) => role.role)
  .join(' and ');
---

<Layout title={cv.seo.title} description={cv.seo.description}>
  <section class="pt-20 pb-16 md:pt-28 max-w-3xl">
    <div
      class="flex flex-col gap-4 mb-1 sm:flex-row sm:items-center sm:justify-between"
    >
      <h1 class="type-page-title">{cv.person.name}</h1>
      <div
        class="group relative flex shrink-0 items-stretch text-xs"
        data-cv-download
        data-cv-format={defaultDownload.format}
        data-cv-options={JSON.stringify(cv.downloads)}
      >
        <a
          href={defaultDownload.href}
          download={defaultDownload.filename}
          class="inline-flex min-h-10 min-w-32 items-center justify-between gap-3 rounded-l-lg border border-border border-r-0 bg-surface/60 px-3.5 py-2 font-medium tracking-[0.01em] text-heading transition-colors group-hover:border-muted group-hover:bg-heading/[0.03]"
          aria-label={`Download CV as ${defaultDownload.badge}`}
          data-cv-download-link
        >
          <span>Download</span>
          <span class="type-micro font-semibold uppercase tracking-[0.08em]"
            >{defaultDownload.badge}</span
          >
        </a>
        <button
          type="button"
          class="inline-flex min-h-10 w-10 items-center justify-center rounded-r-lg border border-border bg-surface/60 text-muted transition-colors group-hover:border-muted group-hover:bg-heading/[0.03] hover:text-heading"
          aria-label="Choose CV format"
          aria-expanded="false"
          data-cv-menu-toggle
        >
          <svg
            aria-hidden="true"
            class="size-3.5"
            viewBox="0 0 16 16"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M4 6L8 10L12 6"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
        <div
          class="absolute inset-x-0 top-full z-20 mt-2 hidden overflow-hidden rounded-lg border border-border bg-surface shadow-xl shadow-black/20"
          data-cv-menu
        >
          <button
            type="button"
            class="flex min-h-10 w-full items-center justify-between gap-3 px-3.5 py-2 text-left text-xs font-medium tracking-[0.01em] text-heading transition-colors hover:bg-heading/[0.04]"
            data-cv-option={alternateDownload.format}
          >
            <span>{alternateDownload.optionTitle}</span>
            <span class="type-micro font-semibold uppercase tracking-[0.08em]"
              >{alternateDownload.badge}</span
            >
          </button>
        </div>
      </div>
    </div>
    <p class="text-muted text-sm mb-2">{cv.person.location}</p>
    <div class="flex flex-wrap gap-3 text-xs text-muted mb-8">
      {
        cv.person.contacts.map((contact, index) => (
          <>
            {index > 0 && <span class="text-dim">&middot;</span>}
            <a
              href={contact.href}
              target={contact.external ? '_blank' : undefined}
              rel={contact.external ? 'noopener noreferrer' : undefined}
              class="hover:text-heading transition-colors"
            >
              {contact.label}
            </a>
          </>
        ))
      }
    </div>

    <p class="type-body italic mb-12">{textFor(cv.summary, 'html')}</p>

    <!-- technical skills -->
    <div class="mb-12">
      <h2 class="type-section-title mb-4">
        {textFor(cv.sections.skills, 'html')}
      </h2>
      <div class="space-y-2 text-sm">
        {
          cv.skills.map((skill) => (
            <p>
              <span class="text-heading font-semibold">{skill.label}:</span>{' '}
              <span class="text-muted">{skill.items.join(', ')}</span>
            </p>
          ))
        }
      </div>
    </div>

    <!-- education -->
    <div class="mb-12">
      <h2 class="type-section-title mb-4">
        {textFor(cv.sections.education, 'html')}
      </h2>
      <div class="border-l border-border pl-6">
        <h3 class="type-panel-title font-bold">{cv.education.institution}</h3>
        <p class="text-muted text-sm">
          {cv.education.degree} &middot; Expected {
            formatDate(cv.education.expected)
          }
        </p>
        <p class="text-muted text-sm mt-1">
          {cv.education.year} &middot; <span class="text-heading font-semibold"
            >{cv.education.distinction}</span
          > ({cv.education.distinctionPeriod})
        </p>
        <p class="text-dim text-xs mt-2">
          {formatModules(cv.education.modules, 'html')}
        </p>
      </div>
    </div>

    <!-- honours -->
    <div class="mb-12">
      <h2 class="type-section-title mb-4">
        {textFor(cv.sections.awards, 'html')}
      </h2>
      <div class="space-y-4">
        {
          cv.awards.map((award) => (
            <div class="bg-surface border border-heading/[0.06] rounded-bento p-4">
              <div class="flex justify-between items-start">
                <h3 class="type-small-title font-bold">
                  {award.title}
                  {award.context ? ` — ${award.context}` : ''}
                </h3>
                <span class="text-dim text-xs shrink-0 ml-4">
                  {formatAwardDates(award.dates, 'html')}
                </span>
              </div>
              <p class="text-muted text-sm mt-1">
                {award.description}
                {award.issuer ? ` — ${award.issuer}` : ''}
              </p>
            </div>
          ))
        }
      </div>
    </div>

    <!-- projects -->
    <div class="mb-12">
      <h2 class="type-section-title mb-4">
        {textFor(cv.sections.projects, 'html')}
      </h2>
      <div class="space-y-4">
        {
          htmlProjects.map((project) => (
            <div class="bg-surface border border-heading/[0.06] rounded-bento p-4">
              <div class="flex justify-between items-start">
                <h3 class="type-small-title font-bold">{project.name}</h3>
                {project.status && (
                  <span class="text-dim text-xs shrink-0 ml-4">
                    {formatProjectStatus(project.status, 'html')}
                  </span>
                )}
              </div>
              <p class="text-dim text-xs mt-1">
                {formatStack(project.stack, 'html')}
              </p>
              <p class="text-muted text-sm mt-2">
                {textFor(project.description, 'html')}
              </p>
            </div>
          ))
        }
      </div>
      <a
        href={cv.projectsIndex.href}
        class="text-fox text-sm mt-3 inline-block hover:underline"
        >{cv.projectsIndex.label} &rarr;</a
      >
    </div>

    <!-- work experience -->
    <div class="mb-12">
      <h2 class="type-section-title mb-4">
        {textFor(cv.sections.workExperience, 'html')}
      </h2>
      <div class="border-l border-border pl-6 space-y-6">
        {
          cv.repairExperience.entries.map((entry) => (
            <div>
              <h3 class="type-panel-title font-bold">{entry.title}</h3>
              <p class="text-muted text-sm">
                {'location' in entry
                  ? `${entry.organisation}, ${entry.location} · ${entry.context}`
                  : `${entry.organisation} ${entry.context} (${entry.year})`}
              </p>
              <p class="text-dim text-sm mt-2">{entry.description}</p>
            </div>
          ))
        }
      </div>
    </div>

    <!-- leadership -->
    <div class="mb-12">
      <h2 class="type-section-title mb-4">
        {textFor(cv.sections.leadership, 'html')}
      </h2>
      <div class="border-l border-border pl-6">
        <h3 class="type-panel-title font-bold">
          {cv.leadership.shortOrganisation}{' '}{cv.leadership.currentRole}
        </h3>
        <p class="text-muted text-sm">
          {cv.leadership.organisation} &middot; {
            cv.leadership.involvementPeriod
          }
        </p>
        <p class="text-dim text-sm mt-2">
          {cv.leadership.description} Previously {previousLeadershipRoles}.
        </p>
      </div>
    </div>

    <!-- interests -->
    <div>
      <h2 class="type-section-title mb-4">
        {textFor(cv.sections.interests, 'html')}
      </h2>
      <p class="type-body">
        {
          cv.interests
            .map((interest) => textFor(interest.description, 'html'))
            .join(' ')
        }
      </p>
    </div>
  </section>

  <script>
    const wrapper = document.querySelector('[data-cv-download]');
    const link = wrapper?.querySelector('[data-cv-download-link]');
    const toggle = wrapper?.querySelector('[data-cv-menu-toggle]');
    const menu = wrapper?.querySelector('[data-cv-menu]');

    type DownloadFormat = 'pdf' | 'tex';
    type DownloadOption = {
      format: DownloadFormat;
      href: string;
      filename: string;
      badge: string;
      optionTitle: string;
    };

    const downloadOptions =
      wrapper instanceof HTMLElement
        ? (JSON.parse(wrapper.dataset.cvOptions ?? '[]') as DownloadOption[])
        : [];
    const downloads = new Map(
      downloadOptions.map((download) => [download.format, download]),
    );

    const renderDownloadLabel = (badge: string) =>
      `<span>Download</span><span class="type-micro font-semibold uppercase tracking-[0.08em]">${badge}</span>`;

    const renderOptionLabel = (format: DownloadFormat) => {
      const option = downloads.get(format);

      return option
        ? `<span>${option.optionTitle}</span><span class="type-micro font-semibold uppercase tracking-[0.08em]">${option.badge}</span>`
        : '';
    };

    const setMenuOpen = (open: boolean) => {
      if (
        !(toggle instanceof HTMLButtonElement) ||
        !(menu instanceof HTMLElement)
      ) {
        return;
      }

      menu.classList.toggle('hidden', !open);
      toggle.setAttribute('aria-expanded', String(open));
    };

    const setFormat = (format: DownloadFormat) => {
      if (
        !(wrapper instanceof HTMLElement) ||
        !(link instanceof HTMLAnchorElement)
      ) {
        return;
      }

      const activeFormat = format === 'tex' ? 'tex' : 'pdf';
      const alternateFormat = activeFormat === 'pdf' ? 'tex' : 'pdf';
      const download = downloads.get(activeFormat);
      const option = menu?.querySelector('[data-cv-option]');

      if (!download) return;

      wrapper.dataset.cvFormat = activeFormat;
      link.href = download.href;
      link.download = download.filename;
      link.setAttribute('aria-label', `Download CV as ${download.badge}`);
      link.innerHTML = renderDownloadLabel(download.badge);

      if (option instanceof HTMLButtonElement) {
        option.dataset.cvOption = alternateFormat;
        option.innerHTML = renderOptionLabel(alternateFormat);
      }
    };

    if (
      wrapper instanceof HTMLElement &&
      toggle instanceof HTMLButtonElement &&
      menu instanceof HTMLElement
    ) {
      toggle.addEventListener('click', () => {
        setMenuOpen(toggle.getAttribute('aria-expanded') !== 'true');
      });

      menu.addEventListener('click', (event) => {
        const option =
          event.target instanceof Element
            ? event.target.closest('[data-cv-option]')
            : null;

        if (option instanceof HTMLButtonElement) {
          setFormat(option.dataset.cvOption === 'pdf' ? 'pdf' : 'tex');
          setMenuOpen(false);
        }
      });

      document.addEventListener('click', (event) => {
        if (event.target instanceof Node && !wrapper.contains(event.target)) {
          setMenuOpen(false);
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          setMenuOpen(false);
        }
      });
    }
  </script>
</Layout>
