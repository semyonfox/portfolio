---
import Layout from '../../layouts/Layout.astro';
import {
  chatApiDocs,
  chatApiJson,
  endpointBlock,
  healthBlock,
} from '../../data/chatApiDocs';

const docs = chatApiDocs;
---

<Layout title={`${docs.title} | Semyon Fox`} description={docs.pageDescription}>
  <section class="pt-20 pb-16 md:pt-28 max-w-3xl">
    <p class="type-kicker mb-4">/docs</p>
    <h1 class="type-page-title mb-3">{docs.title}</h1>
    <p class="type-body mb-10">{docs.summary}</p>

    <h2 class="type-section-title mb-3">Endpoint</h2>
    <pre
      class="bg-surface border border-border rounded-lg px-4 py-3 text-xs text-heading mb-6 overflow-x-auto"><code>{endpointBlock}</code></pre>

    <h2 class="type-section-title mb-3">Request</h2>
    <pre
      class="bg-surface border border-border rounded-lg px-4 py-3 text-xs text-heading mb-3 overflow-x-auto"><code>{chatApiJson.request}</code></pre>
    <ul
      class="text-muted text-sm leading-relaxed space-y-1 mb-8 list-disc pl-5"
    >
      {
        docs.requestRules.map((rule) => (
          <li>
            <code class="text-heading">{rule.term}</code>: {rule.description}
          </li>
        ))
      }
    </ul>

    <h2 class="type-section-title mb-3">Response (200)</h2>
    <pre
      class="bg-surface border border-border rounded-lg px-4 py-3 text-xs text-heading mb-3 overflow-x-auto"><code>{chatApiJson.response}</code></pre>
    <p class="type-body mb-8">{docs.responseSummary}</p>

    <h2 class="type-section-title mb-3">Errors</h2>
    <ul
      class="text-muted text-sm leading-relaxed space-y-1 mb-8 list-disc pl-5"
    >
      {
        docs.errors.map((error) => (
          <li>
            <code class="text-heading">{error.status}</code>:{' '}
            {error.description}
          </li>
        ))
      }
    </ul>

    <h2 class="type-section-title mb-3">Health</h2>
    <pre
      class="bg-surface border border-border rounded-lg px-4 py-3 text-xs text-heading mb-8 overflow-x-auto"><code>{healthBlock}</code></pre>

    <h2 class="type-section-title mb-3">Machine-readable</h2>
    <ul
      class="text-muted text-sm leading-relaxed space-y-1 mb-8 list-disc pl-5"
    >
      {
        docs.links.map((link) => (
          <li>
            {link.label}:{' '}
            <a class="text-fox hover:underline" href={link.href}>
              {link.href}
            </a>
          </li>
        ))
      }
    </ul>

    <h2 class="type-section-title mb-3">Example</h2>
    <pre
      class="bg-surface border border-border rounded-lg px-4 py-3 text-xs text-heading mb-8 overflow-x-auto"><code>{docs.curlExample}</code></pre>

    <h2 class="type-section-title mb-3">Notes for agents</h2>
    <ul
      class="text-muted text-sm leading-relaxed space-y-1 mb-12 list-disc pl-5"
    >
      {docs.agentNotes.map((note) => <li>{note}</li>)}
    </ul>

    <a href="/" class="text-fox text-sm hover:underline">&larr; back home</a>
  </section>
</Layout>
