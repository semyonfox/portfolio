---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import profilePic from '../assets/profilepic.webp';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);
const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
const games = (await getCollection('games')).sort(
  (a, b) => a.data.order - b.data.order,
);

const featured = projects.find((p) => p.data.featured) || projects[0];
const latestPost = posts[0];
const latestGame = games[0];
const secondPost = posts[1];
---

<Layout title="Semyon Fox | Developer, Swimmer, Builder">
  <!-- hero -->
  <section class="pt-20 pb-16 md:pt-28 md:pb-20">
    <p class="type-kicker mb-4">CS &middot; University of Galway</p>
    <h1 class="type-hero mb-6">
      Dev<span class="text-fox">.</span><br />
      <span class="text-muted">Swim</span><span class="text-fox">.</span><br />
      <span class="text-dim">Build</span><span class="text-fox">.</span>
    </h1>
    <div class="hero-copy max-w-md">
      <p class="type-body mb-8">
        <span class="block"
          >I build things with <span class="hero-mark">code</span> and break things
          with <span class="hero-mark">curiosity</span>.</span
        >
        <span class="block"
          >Currently running <span class="hero-mark">54 containers</span> on a repurposed
          laptop</span
        >
        <span class="block"
          >and racing toward <span class="hero-mark">sub-1min 100m</span>.</span
        >
      </p>
      <p class="type-micro mb-5 flex items-center gap-2 text-muted">
        <span
          class="h-1.5 w-1.5 shrink-0 rounded-full bg-fox"
          aria-hidden="true"
        ></span>
        Seeking a Jan&ndash;Aug 2027 software engineering / platform / SRE
        placement.
      </p>
      <div class="flex gap-3">
        <a
          href="/projects"
          data-analytics-placement="cta"
          class="bg-fox text-heading font-semibold text-sm px-5 py-2.5 rounded-lg hover:brightness-110 transition-all"
        >
          view projects
        </a>
        <a
          href="/blog"
          data-analytics-placement="cta"
          class="border border-border text-muted font-medium text-sm px-5 py-2.5 rounded-lg hover:text-heading hover:border-muted transition-colors"
        >
          read blog
        </a>
      </div>
    </div>
  </section>

  <!-- bento grid -->
  <section class="pb-16">
    <p class="type-kicker mb-6">what i've been up to</p>

    <div class="grid grid-cols-1 md:grid-cols-5 gap-3">
      <!-- featured project (spans 2 rows) -->
      {
        featured && (
          <a
            href="/projects"
            class="md:col-span-3 md:row-span-2 bg-surface border border-heading/[0.06] rounded-bento p-6 flex flex-col justify-between hover:border-heading/10 transition-colors group"
          >
            <div>
              <p class="type-micro text-fox font-semibold uppercase mb-3">
                featured project
              </p>
              <h3 class="type-card-title mb-2 group-hover:text-fox/90 transition-colors">
                {featured.data.title}
              </h3>
              <p class="type-body">{featured.data.description}</p>
            </div>
            <div class="flex flex-wrap gap-1.5 mt-4">
              {featured.data.tags.slice(0, 4).map((tag) => (
                <span class="bg-border px-2 py-0.5 rounded text-[11px] text-muted">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        )
      }

      <!-- game card -->
      {
        latestGame && (
          <a
            href="/games"
            class="md:col-span-2 bg-surface border border-heading/[0.06] rounded-bento overflow-hidden hover:border-heading/10 transition-colors group"
          >
            {latestGame.data.thumbnail ? (
              <img
                src={latestGame.data.thumbnail}
                alt=""
                width="960"
                height="540"
                class="w-full h-28 object-cover border-b border-border"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="bg-border h-28 flex items-center justify-center">
                <span class="text-lg font-black text-dim/40">PLAY</span>
              </div>
            )}
            <div class="p-4">
              <p class="type-micro uppercase mb-1">game</p>
              <h3 class="type-small-title group-hover:text-fox/90 transition-colors">
                {latestGame.data.title}
              </h3>
              <p class="text-dim text-xs mt-1">{latestGame.data.tech}</p>
            </div>
          </a>
        )
      }

      <!-- latest blog -->
      {
        latestPost && (
          <a
            href={`/blog/${latestPost.id}`}
            class="md:col-span-2 bg-surface border border-heading/[0.06] rounded-bento p-4 hover:border-heading/10 transition-colors group"
          >
            <p class="type-micro uppercase mb-1.5">blog</p>
            <h3 class="type-small-title group-hover:text-fox/90 transition-colors">
              {latestPost.data.title}
            </h3>
            <p class="text-dim text-xs mt-1">
              {new Date(latestPost.data.date).toLocaleDateString('en-IE', {
                month: 'short',
                year: 'numeric',
              })}
            </p>
          </a>
        )
      }

      <!-- row 2 -->
      {
        projects[1] && (
          <a
            href="/projects"
            class="md:col-span-2 bg-surface border border-heading/[0.06] rounded-bento p-4 hover:border-heading/10 transition-colors group"
          >
            <p class="type-micro uppercase mb-1.5">project</p>
            <h3 class="type-small-title group-hover:text-fox/90 transition-colors">
              {projects[1].data.title}
            </h3>
            <p class="text-muted text-xs mt-1 line-clamp-2">
              {projects[1].data.description}
            </p>
          </a>
        )
      }

      {
        secondPost && (
          <a
            href={`/blog/${secondPost.id}`}
            class="md:col-span-2 bg-surface border border-heading/[0.06] rounded-bento p-4 hover:border-heading/10 transition-colors group"
          >
            <p class="type-micro uppercase mb-1.5">blog</p>
            <h3 class="type-small-title group-hover:text-fox/90 transition-colors">
              {secondPost.data.title}
            </h3>
            <p class="text-dim text-xs mt-1">
              {new Date(secondPost.data.date).toLocaleDateString('en-IE', {
                month: 'short',
                year: 'numeric',
              })}
            </p>
          </a>
        )
      }

      <a
        href="/games"
        class="md:col-span-1 bg-surface border border-heading/[0.06] rounded-bento p-4 flex flex-col items-center justify-center text-center hover:border-heading/10 transition-colors group"
      >
        <span class="text-lg font-black text-dim/40 mb-1">~/games</span>
        <p
          class="text-muted text-xs group-hover:text-heading transition-colors"
        >
          play
        </p>
      </a>
    </div>
  </section>

  <!-- linkedin -->
  <section class="pb-16">
    <div class="flex items-center gap-3 mb-6">
      <svg class="w-4 h-4 text-dim" fill="currentColor" viewBox="0 0 24 24"
        ><path
          d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
        ></path></svg
      >
      <p class="type-kicker">on linkedin</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-3">
      <a
        href="https://www.linkedin.com/in/semyon-fox-968685249/"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-surface border border-heading/[0.06] rounded-bento p-5 hover:border-heading/10 transition-colors group"
      >
        <p class="text-dim text-xs mb-2">June 2026 &middot; 479 impressions</p>
        <h3
          class="type-small-title font-bold group-hover:text-fox/90 transition-colors mb-2"
        >
          WebExpo Prague: AI, UX, and Product Lessons
        </h3>
        <p class="text-muted text-xs leading-relaxed line-clamp-3">
          I joined the University of Limerick Computer Society trip to Prague
          for WebExpo and came back with new ideas, new friends, and a stronger
          desire to see the world.
        </p>
      </a>

      <a
        href="https://www.linkedin.com/in/semyon-fox-968685249/"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-surface border border-heading/[0.06] rounded-bento p-5 hover:border-heading/10 transition-colors group"
      >
        <p class="text-dim text-xs mb-2">Feb 2026 &middot; 236 impressions</p>
        <h3
          class="type-small-title font-bold group-hover:text-fox/90 transition-colors mb-2"
        >
          CompSoc CTF 2026
        </h3>
        <p class="text-muted text-xs leading-relaxed line-clamp-3">
          Incredibly proud of what we achieved. As Auditor, it was rewarding to
          see months of planning come together for our biggest event yet, with
          students travelling from across Ireland to compete.
        </p>
      </a>

      <a
        href="https://www.linkedin.com/in/semyon-fox-968685249/"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-surface border border-heading/[0.06] rounded-bento p-5 hover:border-heading/10 transition-colors group"
      >
        <p class="text-dim text-xs mb-2">Oct 2025 &middot; 579 impressions</p>
        <h3
          class="type-small-title font-bold group-hover:text-fox/90 transition-colors mb-2"
        >
          Migrated from Google Photos to Immich
        </h3>
        <p class="text-muted text-xs leading-relaxed line-clamp-3">
          I ran out of storage on Google and didn't want to pay for more. More
          importantly, I realized I didn't want Google controlling all my family
          memories. Immich is fast, reliable, and surprisingly close to Google
          Photos.
        </p>
      </a>

      <a
        href="https://www.linkedin.com/in/semyon-fox-968685249/"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-surface border border-heading/[0.06] rounded-bento p-5 hover:border-heading/10 transition-colors group"
      >
        <p class="text-dim text-xs mb-2">Aug 2025 &middot; 1,339 impressions</p>
        <h3
          class="type-small-title font-bold group-hover:text-fox/90 transition-colors mb-2"
        >
          From Broken Laptop to Full Homelab
        </h3>
        <p class="text-muted text-xs leading-relaxed line-clamp-3">
          One year ago, my Dell XPS 15's hinge crushed the screen. What was once
          a great laptop was now half-useless. While researching what to do, I
          came across a video: "Turn it into a server." So I did.
        </p>
      </a>
    </div>
  </section>

  <!-- about -->
  <section class="pb-16">
    <h2 class="type-section-title mb-6">About me</h2>
    <div class="grid md:grid-cols-[3fr_1fr] gap-8 items-start">
      <div class="space-y-4 type-body max-w-[70ch]">
        <p>
          I am Semyon, a Computer Science student in Galway. Most of my projects
          come from something I actually needed: tracking swimming work,
          automating admin, running my own services, or learning how a system
          behaves when it is not just a tutorial.
        </p>
        <p>
          The homelab started with an old Dell XPS that was no longer useful as
          a laptop. It turned into a place for Docker, Jenkins, nginx,
          Cloudflare tunnels, storage, backups, dashboards, and the sort of
          mistakes that actually teach you something.
        </p>
        <p>
          Swimming is the other big part of my week. I train, race, track
          progress, and keep trying to make the 100m clock less annoying.
        </p>
        <p>
          CompSoc has been a good pressure test outside normal coursework. I
          have worked on events, CTF logistics, sponsorships, finance,
          communications, and the bits of software that have to survive real
          users.
        </p>
        <p>
          Away from code, I edit video, make things in the workshop, and watch a
          lot of people who explain hard topics well. This site is where the
          useful parts of all that end up.
        </p>
      </div>
      <div class="hidden md:block">
        <Image
          src={profilePic}
          alt="Semyon Fox"
          class="rounded-2xl border border-border w-full aspect-square object-cover"
          width={400}
          height={400}
          loading="lazy"
        />
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero-copy {
    position: relative;
  }

  .hero-mark {
    color: #d4d0ca;
    font-weight: 600;
    background: linear-gradient(
      180deg,
      transparent 64%,
      rgba(249, 115, 22, 0.3) 64%
    );
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }
</style>
