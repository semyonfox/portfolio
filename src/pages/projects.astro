---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);
const personal = allProjects.filter((p) => p.data.category === 'personal');
const academic = allProjects.filter((p) => p.data.category === 'academic');
---

<Layout
  title="Projects | Semyon Fox"
  description="Technical projects in web development, DevOps, and infrastructure."
>
  <section class="pt-20 pb-16 md:pt-28">
    <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-2">
      Projects
    </h1>
    <p class="text-muted text-sm mb-16">
      things i've built, broken, and learned from
    </p>

    <!-- personal -->
    <div class="mb-16">
      <h2 class="text-xs text-dim uppercase tracking-[3px] mb-6">Personal</h2>
      <div class="grid gap-4">
        {
          personal.map((project) => (
            <article class="bg-surface border border-heading/[0.06] rounded-bento p-6 hover:border-heading/10 transition-colors">
              <div class="flex items-start justify-between gap-4 mb-3">
                <div>
                  {project.data.featured && (
                    <p class="text-fox text-[11px] font-semibold uppercase tracking-widest mb-2">
                      featured
                    </p>
                  )}
                  <h3 class="text-heading text-lg font-bold tracking-tight">
                    {project.data.title}
                  </h3>
                </div>
                <div class="flex gap-2 shrink-0">
                  {project.data.live && (
                    <a
                      href={project.data.live}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-dim hover:text-heading transition-colors text-xs border border-border rounded px-2 py-1"
                    >
                      live
                    </a>
                  )}
                  {project.data.github && (
                    <a
                      href={project.data.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-dim hover:text-heading transition-colors"
                      aria-label={`${project.data.title} on GitHub`}
                    >
                      <svg
                        class="w-5 h-5"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
                      </svg>
                    </a>
                  )}
                </div>
              </div>
              <p class="text-muted text-sm leading-relaxed mb-4">
                {project.data.description}
              </p>
              <div class="flex flex-wrap gap-1.5">
                {project.data.tags.map((tag) => (
                  <span class="bg-border px-2 py-0.5 rounded text-[11px] text-muted">
                    {tag}
                  </span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <!-- academic -->
    <div>
      <h2 class="text-xs text-dim uppercase tracking-[3px] mb-6">Academic</h2>
      <div class="grid gap-4">
        {
          academic.map((project) => (
            <article class="bg-surface border border-heading/[0.06] rounded-bento p-6 hover:border-heading/10 transition-colors">
              <div class="flex items-start justify-between gap-4 mb-3">
                <h3 class="text-heading text-lg font-bold tracking-tight">
                  {project.data.title}
                </h3>
                <div class="flex gap-2 shrink-0">
                  {project.data.github && (
                    <a
                      href={project.data.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-dim hover:text-heading transition-colors"
                      aria-label={`${project.data.title} on GitHub`}
                    >
                      <svg
                        class="w-5 h-5"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
                      </svg>
                    </a>
                  )}
                </div>
              </div>
              <p class="text-muted text-sm leading-relaxed mb-4">
                {project.data.description}
              </p>
              <div class="flex flex-wrap gap-1.5">
                {project.data.tags.map((tag) => (
                  <span class="bg-border px-2 py-0.5 rounded text-[11px] text-muted">
                    {tag}
                  </span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
