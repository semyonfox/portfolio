---
import Layout from '../layouts/Layout.astro';
import { categoryOrder, people, type PersonCategory } from '../data/people';
import semanticGraph from '../data/people-graph.json';

type SemanticNode = {
  source: string;
  wikiTitle: string | null;
  wikiUrl: string | null;
  summary: string;
  graphWeight: number;
};

const semanticNodes = semanticGraph.nodes as Record<
  string,
  SemanticNode | undefined
>;

const categoryMeta: Record<PersonCategory, { label: string; color: string }> = {
  dev: { label: 'Dev / Software', color: '#e8702a' },
  science: { label: 'Math / Science / Engineering', color: '#40b8ff' },
  hardware: { label: 'Hardware / Maker / Tech', color: '#119b74' },
  swimming: { label: 'Swimming / Sport', color: '#16b8d8' },
  games: { label: 'Games / Internet', color: '#6f4bd6' },
  creative: { label: 'Film / Creative', color: '#c88a13' },
  chess: { label: 'Chess', color: '#d84848' },
  comedy: { label: 'Comedy / Entertainment', color: '#686874' },
};

const categoryCenters: Record<PersonCategory, { x: number; y: number }> = {
  dev: { x: 210, y: 160 },
  science: { x: 500, y: 120 },
  hardware: { x: 790, y: 170 },
  swimming: { x: 160, y: 450 },
  games: { x: 425, y: 500 },
  creative: { x: 680, y: 450 },
  chess: { x: 905, y: 420 },
  comedy: { x: 560, y: 315 },
};

const grouped = Object.fromEntries(
  categoryOrder.map((category) => [
    category,
    people
      .filter((person) => person.category === category)
      .sort((a, b) => b.weight - a.weight || a.name.localeCompare(b.name)),
  ]),
) as Record<PersonCategory, typeof people>;

const nodes = categoryOrder.flatMap((category) => {
  const members = grouped[category];
  const center = categoryCenters[category];

  return members.map((person, index) => {
    const angle = (Math.PI * 2 * index) / Math.max(members.length, 1);
    const ring = 36 + Math.floor(index / 5) * 34 + (5 - person.weight) * 5;
    const driftX = Math.sin(index * 1.7) * 10;
    const driftY = Math.cos(index * 1.3) * 8;
    const graphWeight =
      semanticNodes[person.slug]?.graphWeight || person.weight;
    return {
      ...person,
      x: center.x + Math.cos(angle) * ring + driftX,
      y: center.y + Math.sin(angle) * ring + driftY,
      visualWeight: Math.max(
        person.weight,
        Math.round((person.weight + graphWeight) / 2),
      ),
      color: categoryMeta[category].color,
    };
  });
});

const slugSet = new Set(nodes.map((node) => node.slug));
const explicitEdges = new Set<string>();
const edges: Array<{ source: string; target: string; inferred: boolean }> = [];

for (const person of nodes) {
  for (const target of person.connections || []) {
    if (!slugSet.has(target)) continue;
    const key = [person.slug, target].sort().join(':');
    if (explicitEdges.has(key)) continue;
    explicitEdges.add(key);
    edges.push({
      source: person.slug < target ? person.slug : target,
      target: person.slug < target ? target : person.slug,
      inferred: false,
    });
  }
}

for (const edge of semanticGraph.semanticEdges) {
  const key = [edge.source, edge.target].sort().join(':');
  if (explicitEdges.has(key)) continue;
  if (!slugSet.has(edge.source) || !slugSet.has(edge.target)) continue;
  edges.push({ source: edge.source, target: edge.target, inferred: true });
}

const demoSelectedSlug = 'fireship';
const demoNeighborSlugs = new Set(
  edges.flatMap((edge) => {
    if (edge.source === demoSelectedSlug) return [edge.target];
    if (edge.target === demoSelectedSlug) return [edge.source];
    return [];
  }),
);

const variants = [
  {
    id: 'foxprint',
    title: 'Fox Accent x Blueprint',
    note: 'fox accent darkness with blueprint-style grid discipline. stronger selected-state glow and clearer neighbour links.',
    bg: '#151313',
    edge: '#8c93b0',
    edgeOpacity: '0.18',
    inferOpacity: '0.08',
    glowOpacity: '0.03',
    ringOpacity: '0.05',
    labelOpacity: '0.07',
    nodeStyle: 'dot-glow',
  },
  {
    id: 'foxprint-alt',
    title: 'Fox Accent x Blueprint Alt',
    note: 'same field and edge language, but with a tighter node mark and a more precise selected-state ring.',
    bg: '#151313',
    edge: '#8c93b0',
    edgeOpacity: '0.18',
    inferOpacity: '0.08',
    glowOpacity: '0.03',
    ringOpacity: '0.05',
    labelOpacity: '0.07',
    nodeStyle: 'pin-glow',
  },
];
---

<Layout
  title="People Lab | Semyon Fox"
  description="Style explorations for the people graph."
>
  <section class="pt-20 pb-12 md:pt-28">
    <h1 class="type-page-title mb-3">People Graph Lab</h1>
    <p class="type-body mb-4">
      quick style comparisons for the graph aesthetic, keeping it within the
      portfolio's visual language
    </p>
    <p class="type-caption max-w-2xl">
      same node and edge data, different rendering choices. this is for picking
      the feel, not the final interaction model.
    </p>
  </section>

  <section class="pb-16">
    <div class="grid gap-6">
      {
        variants.map((variant) => (
          <article class="bg-surface border border-heading/[0.06] rounded-bento p-5">
            <div class="flex items-start justify-between gap-6 mb-4">
              <div>
                <h2 class="type-section-title">{variant.title}</h2>
                <p class="type-body mt-1 max-w-2xl">{variant.note}</p>
              </div>
              <span class="type-micro uppercase">preview</span>
            </div>

            <div class="flex flex-wrap gap-2 mb-4 text-[11px]">
              <span class="bg-border px-2 py-1 rounded text-muted">
                field: {variant.bg}
              </span>
              <span class="bg-border px-2 py-1 rounded text-muted">
                links: {variant.edgeOpacity}/{variant.inferOpacity}
              </span>
              <span class="bg-border px-2 py-1 rounded text-muted">
                labels: {variant.labelOpacity}
              </span>
            </div>

            <div class="rounded-bento border border-heading/[0.06] overflow-hidden">
              <svg viewBox="0 0 1000 620" class="w-full h-auto">
                <rect x="0" y="0" width="1000" height="620" fill={variant.bg} />

                {(variant.id === 'foxprint' ||
                  variant.id === 'foxprint-alt') && (
                  <g opacity="0.14">
                    {Array.from({ length: 20 }).map((_, i) => (
                      <line
                        x1={i * 50}
                        y1="0"
                        x2={i * 50}
                        y2="620"
                        stroke="#4a4e63"
                        stroke-width="0.6"
                      />
                    ))}
                    {Array.from({ length: 13 }).map((_, i) => (
                      <line
                        x1="0"
                        y1={i * 50}
                        x2="1000"
                        y2={i * 50}
                        stroke="#4a4e63"
                        stroke-width="0.6"
                      />
                    ))}
                  </g>
                )}

                {edges.map((edge) => {
                  const source = nodes.find(
                    (node) => node.slug === edge.source,
                  )!;
                  const target = nodes.find(
                    (node) => node.slug === edge.target,
                  )!;
                  const selectedEdge =
                    (variant.id === 'foxprint' ||
                      variant.id === 'foxprint-alt') &&
                    (edge.source === demoSelectedSlug ||
                      edge.target === demoSelectedSlug);
                  return (
                    <line
                      x1={source.x}
                      y1={source.y}
                      x2={target.x}
                      y2={target.y}
                      stroke={
                        selectedEdge
                          ? source.slug === demoSelectedSlug
                            ? source.color
                            : target.color
                          : variant.edge
                      }
                      stroke-opacity={
                        selectedEdge
                          ? '0.72'
                          : edge.inferred
                            ? variant.inferOpacity
                            : variant.edgeOpacity
                      }
                      stroke-width={
                        selectedEdge ? '1.8' : edge.inferred ? '0.7' : '1'
                      }
                    />
                  );
                })}

                {nodes.map((node) => {
                  const isSelected =
                    (variant.id === 'foxprint' ||
                      variant.id === 'foxprint-alt') &&
                    node.slug === demoSelectedSlug;
                  const isNeighbor =
                    (variant.id === 'foxprint' ||
                      variant.id === 'foxprint-alt') &&
                    demoNeighborSlugs.has(node.slug);
                  const isActive = isSelected || isNeighbor;
                  return (
                    <g>
                      {variant.nodeStyle === 'mist' && (
                        <>
                          <circle
                            cx={node.x}
                            cy={node.y}
                            r={8 + node.visualWeight * 2.6}
                            fill={node.color}
                            fill-opacity={variant.glowOpacity}
                          />
                          <circle
                            cx={node.x}
                            cy={node.y}
                            r={2 + node.visualWeight * 1.8}
                            fill={node.color}
                            fill-opacity={variant.ringOpacity}
                            stroke={node.color}
                            stroke-width="1.1"
                          />
                          <circle
                            cx={node.x}
                            cy={node.y}
                            r={1.3 + node.visualWeight * 0.9}
                            fill={node.color}
                          />
                        </>
                      )}

                      {variant.nodeStyle === 'dot' && (
                        <>
                          <circle
                            cx={node.x}
                            cy={node.y}
                            r={0.8 + node.visualWeight * 0.85}
                            fill={node.color}
                          />
                          {node.visualWeight >= 4 && (
                            <circle
                              cx={node.x}
                              cy={node.y}
                              r={2.2 + node.visualWeight * 0.65}
                              fill="none"
                              stroke={node.color}
                              stroke-opacity="0.22"
                              stroke-width="0.8"
                            />
                          )}
                        </>
                      )}

                      {variant.nodeStyle === 'dot-flat' && (
                        <>
                          <circle
                            cx={node.x}
                            cy={node.y}
                            r={1 + node.visualWeight * 0.78}
                            fill={node.color}
                          />
                        </>
                      )}

                      {variant.nodeStyle === 'dot-glow' && (
                        <>
                          <circle
                            cx={node.x}
                            cy={node.y}
                            r={
                              isActive
                                ? 8 + node.visualWeight * 2.1
                                : 4 + node.visualWeight * 1.6
                            }
                            fill={node.color}
                            fill-opacity={isActive ? '0.16' : '0.06'}
                          />
                          <circle
                            cx={node.x}
                            cy={node.y}
                            r={
                              isActive
                                ? 1.3 + node.visualWeight * 0.95
                                : 0.9 + node.visualWeight * 0.9
                            }
                            fill={node.color}
                          />
                          {isActive && (
                            <circle
                              cx={node.x}
                              cy={node.y}
                              r={3 + node.visualWeight * 0.9}
                              fill="none"
                              stroke={node.color}
                              stroke-opacity="0.4"
                              stroke-width="1"
                            />
                          )}
                        </>
                      )}

                      {variant.nodeStyle === 'pin' && (
                        <>
                          <circle
                            cx={node.x}
                            cy={node.y}
                            r={0.9 + node.visualWeight * 0.82}
                            fill={node.color}
                          />
                          <circle
                            cx={node.x}
                            cy={node.y}
                            r={1.7 + node.visualWeight * 0.55}
                            fill="none"
                            stroke={node.color}
                            stroke-opacity="0.16"
                            stroke-width="0.65"
                          />
                        </>
                      )}

                      {variant.nodeStyle === 'pin-glow' && (
                        <>
                          {isActive && (
                            <circle
                              cx={node.x}
                              cy={node.y}
                              r={6 + node.visualWeight * 1.3}
                              fill={node.color}
                              fill-opacity="0.1"
                            />
                          )}
                          <circle
                            cx={node.x}
                            cy={node.y}
                            r={1 + node.visualWeight * 0.76}
                            fill={node.color}
                          />
                          <circle
                            cx={node.x}
                            cy={node.y}
                            r={
                              isActive
                                ? 2.8 + node.visualWeight * 0.72
                                : 1.8 + node.visualWeight * 0.48
                            }
                            fill="none"
                            stroke={node.color}
                            stroke-opacity={isActive ? '0.42' : '0.16'}
                            stroke-width={isActive ? '1' : '0.65'}
                          />
                        </>
                      )}

                      {isSelected && (
                        <>
                          <circle
                            cx={node.x}
                            cy={node.y}
                            r={10 + node.visualWeight * 1.5}
                            fill={node.color}
                            fill-opacity="0.12"
                          />
                          <circle
                            cx={node.x}
                            cy={node.y}
                            r={4.5 + node.visualWeight * 0.95}
                            fill="none"
                            stroke={node.color}
                            stroke-opacity="0.7"
                            stroke-width="1.2"
                          />
                        </>
                      )}

                      <text
                        x={node.x}
                        y={node.y + 16}
                        text-anchor="middle"
                        fill="#d8dbef"
                        font-size={node.weight >= 4 ? '11' : '10'}
                        opacity={
                          isActive
                            ? '0.92'
                            : node.weight >= 5
                              ? String(Number(variant.labelOpacity) + 0.08)
                              : variant.labelOpacity
                        }
                      >
                        {node.name}
                      </text>
                    </g>
                  );
                })}
              </svg>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</Layout>
