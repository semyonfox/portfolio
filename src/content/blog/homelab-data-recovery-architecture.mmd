    classDef local fill:#10251a,stroke:#4fa66b,color:#f0f0f0,stroke-width:2px;
    classDef offsite fill:#25180f,stroke:#e8702a,color:#f0f0f0,stroke-width:2px;
    style PRIMARY fill:#101010,stroke:#303030,stroke-width:2px;
    style LOCAL fill:#101010,stroke:#303030,stroke-width:2px;
    style OFFSITE fill:#101010,stroke:#303030,stroke-width:2px;
