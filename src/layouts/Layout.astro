---
import { ClientRouter } from 'astro:transitions';
import Chatbot from '../components/Chatbot.tsx';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Semyon Fox - Developer, swimmer, tinkerer." } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'home' },
  { href: '/projects', label: 'projects' },
  { href: '/games', label: 'games' },
  { href: '/blog', label: 'blog' },
  { href: '/cv', label: 'cv' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Semyon Fox" />
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&display=swap" rel="stylesheet" />
    <!-- og -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={new URL('/profilepic.webp', Astro.site || 'https://semyon.ie').href} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={Astro.url.href} />
    <ClientRouter />
    <title>{title}</title>
  </head>
  <body>
    <a class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-fox focus:text-white focus:px-4 focus:py-2 focus:rounded" href="#main">
      Skip to main content
    </a>

    <!-- nav -->
    <header class="sticky top-0 z-40 border-b border-border backdrop-blur-md bg-bg/80">
      <div class="max-w-6xl mx-auto flex items-center justify-between px-6 py-4">
        <a href="/" class="text-heading font-extrabold text-lg tracking-tight hover:opacity-80 transition-opacity">
          semyon fox
        </a>
        <nav aria-label="Primary" class="hidden md:block">
          <ul class="flex gap-6 text-sm">
            {navLinks.map(link => (
              <li>
                <a
                  href={link.href}
                  class:list={[
                    'relative pb-1 transition-colors',
                    currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                      ? 'text-heading after:absolute after:bottom-0 after:left-0 after:right-0 after:h-0.5 after:bg-fox after:rounded-full'
                      : 'text-muted hover:text-heading',
                  ]}
                  aria-current={currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? 'page' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
        <!-- mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden text-muted hover:text-heading transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
      <!-- mobile nav -->
      <nav id="mobile-menu" class="hidden md:hidden border-t border-border" aria-label="Mobile navigation">
        <ul class="flex flex-col px-6 py-4 gap-3 text-sm">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'block py-1 transition-colors',
                  currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                    ? 'text-fox'
                    : 'text-muted hover:text-heading',
                ]}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <main id="main" class="max-w-6xl mx-auto px-6">
      <slot />
    </main>

    <!-- contact footer -->
    <footer class="border-t border-border mt-24">
      <div class="max-w-6xl mx-auto px-6 py-16">
        <div class="grid md:grid-cols-2 gap-12">
          <div>
            <h2 class="text-2xl font-extrabold tracking-tight mb-4">Get in touch</h2>
            <p class="text-muted text-sm mb-6">Have a question or want to collaborate? Send me a message.</p>
            <form action="https://formspree.io/f/mvgpyblo" method="POST" class="space-y-4">
              <input
                type="text"
                name="name"
                autocomplete="name"
                required
                placeholder="Your name"
                class="w-full bg-surface border border-border rounded-lg px-4 py-3 text-sm text-heading placeholder:text-dim focus:outline-none focus:border-fox/50 focus:ring-1 focus:ring-fox/25 transition-colors"
              />
              <input
                type="email"
                name="email"
                autocomplete="email"
                required
                placeholder="Your email"
                class="w-full bg-surface border border-border rounded-lg px-4 py-3 text-sm text-heading placeholder:text-dim focus:outline-none focus:border-fox/50 focus:ring-1 focus:ring-fox/25 transition-colors"
              />
              <textarea
                name="message"
                required
                placeholder="Your message"
                rows="4"
                class="w-full bg-surface border border-border rounded-lg px-4 py-3 text-sm text-heading placeholder:text-dim focus:outline-none focus:border-fox/50 focus:ring-1 focus:ring-fox/25 transition-colors resize-none"
              ></textarea>
              <button
                type="submit"
                class="bg-fox text-white font-semibold text-sm px-6 py-3 rounded-lg hover:brightness-110 transition-all"
              >
                Send message
              </button>
            </form>
          </div>
          <div class="flex flex-col justify-center">
            <p class="text-muted text-sm mb-4">Connect with me</p>
            <div class="flex gap-4">
              <a
                href="https://www.linkedin.com/in/semyon-fox-968685249/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-muted hover:text-heading transition-colors"
                aria-label="LinkedIn"
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
              <a
                href="mailto:semyon.fox@gmail.com"
                class="text-muted hover:text-heading transition-colors"
                aria-label="Email"
              >
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </a>
              <a
                href="https://github.com/semyonfox"
                target="_blank"
                rel="noopener noreferrer"
                class="text-muted hover:text-heading transition-colors"
                aria-label="GitHub"
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
              </a>
            </div>
            <p class="text-dim text-xs mt-8">&copy; 2025 Semyon Fox</p>
            <p class="text-dim text-[10px] mt-1">favicon made with <a href="https://favicon.io" target="_blank" rel="noopener noreferrer" class="hover:text-muted transition-colors">favicon.io</a></p>
          </div>
        </div>
      </div>
    </footer>

    <Chatbot client:load />

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      if (btn && menu) {
        btn.addEventListener('click', () => {
          const expanded = btn.getAttribute('aria-expanded') === 'true';
          btn.setAttribute('aria-expanded', String(!expanded));
          menu.classList.toggle('hidden');
        });
      }
    </script>
  </body>
</html>
