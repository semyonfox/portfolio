OPENROUTER_API_KEY=your-openrouter-api-key
CHAT_MODEL=deepseek/deepseek-v4-flash
ANALYTICS_SALT=replace-with-a-long-random-value
TUNNEL_TOKEN=your-tunnel-token-here
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_EMAIL_API_TOKEN=your-email-sending-api-token
# Must be an exact verified destination address to remain free on Workers Free.
CONTACT_TO_EMAIL=your-verified-inbox@example.com
CONTACT_FROM_EMAIL=contact@semyon.ie

# Standalone Jenkins image bootstrap (not consumed by docker-compose.yml)
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=change-me-now
JENKINS_URL=https://semyon.ie/jenkins/
