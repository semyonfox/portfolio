{
  "name": "portfolio",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "people:graph": "node --experimental-strip-types scripts/generate-people-graph.mjs",
    "lint": "prettier --check 'src/**/*.{astro,ts,tsx,css}'",
    "format": "prettier --write 'src/**/*.{astro,ts,tsx,css}'",
    "check": "astro check && pnpm run lint",
    "deploy": "ssh semyon@server 'cd portfolio && git pull && docker compose build && docker compose up -d'"
  },
  "dependencies": {
    "@astrojs/preact": "^5.1.2",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource/inter": "^5.2.8",
    "astro": "^6.1.10",
    "preact": "^10.29.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@tailwindcss/vite": "^4.2.4",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": "^3.1.2",
      "yaml": "^2.8.3",
      "devalue": "^5.8.1",
      "esbuild": "^0.28.1"
    }
  }
}
